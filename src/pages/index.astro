---
import Layout from '../layouts/Layout.astro';
import workExperience from '../data/Jobs';
import education from '../data/education';
import languages from '../data/languages';
import { Image } from 'astro:assets';
import profilePic from '../assets/pp2.png';

const mainJobs = workExperience.filter(job => job.company !== 'Thai Culture Association');
const extracurriculars = workExperience.filter(job => job.company === 'Thai Culture Association');

const featuredProjects = [
  {
    title: 'Pawse',
    summary: 'A phone lockbox that physically locks your phone during focus sessions, with AI-powered notification filtering via MobileBERT.',
    tags: ['Python', 'MobileBERT', 'ESP32', 'React Native', 'BLE', 'Supabase'],
    href: '/projects/pawse',
  },
  {
    title: 'Ableware',
    summary: 'Voice-controlled assistive lift system. A Raspberry Pi listens for wake words and sends commands over WebSocket to coordinate hardware and simulation.',
    tags: ['Python', 'Raspberry Pi', 'Arduino', 'WebSocket', 'FastAPI', 'TypeScript'],
    href: '/projects/ableware',
  },
  {
    title: 'DramaTracker',
    summary: 'Full-stack movie tracking app with a content-based filtering recommendation engine using TF-IDF cosine similarity.',
    tags: ['React.js', 'Node.js', 'PostgreSQL', 'Python', 'Flask', 'TMDB API'],
    href: '/projects/drama-tracker',
  },
];

function formatDate(dateStr: string): string {
  if (!dateStr) return 'Present';
  const d = new Date(dateStr);
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<Layout title="Linh On | Portfolio" description="Software Engineer & Embedded Systems Engineer — MS CS student at UC Irvine" scrollSmooth={true}>

  <!-- ── HERO ── -->
  <section class="px-8 md:px-20 lg:px-32 py-12 flex flex-col lg:flex-row gap-10 items-center">
    <!-- Left: profile info -->
    <div class="flex flex-col items-center lg:items-start gap-5 lg:w-1/2">
      <div class="relative">
        <div class="speech-bubble">Hello, I'm Linh!</div>
        <Image
          src={profilePic}
          alt="Linh On"
          class="w-48 h-48 rounded-full object-cover border-4 border-gray-100 shadow-md"
          width={192}
          height={192}
        />
      </div>
      <div class="text-center lg:text-left">
        <h1 class="text-4xl font-bold text-gray-900 mb-2">Linh On</h1>
        <p class="text-lg text-gray-500 font-medium">Software Engineer &amp; Embedded Systems Engineer</p>
      </div>
      <p class="text-gray-600 leading-relaxed text-center lg:text-left max-w-md">
        MS Computer Science student at UC Irvine (expected Dec 2026). I build things across
        the stack — from full-stack web apps to embedded systems and robotics.
      </p>
      <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
        <a
          href="/resume.pdf"
          download
          class="px-5 py-2.5 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors"
        >
          Download CV
        </a>
        <a
          href="https://github.com/linh-on"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/linh-m-on/"
          target="_blank"
          rel="noopener noreferrer"
          class="px-5 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors"
        >
          LinkedIn
        </a>
      </div>
    </div>

    <!-- Right: mini-breadboard preview card -->
    <div class="lg:w-2/3 w-full">
      <div class="bb-preview">
        <div class="bbp-rail">
          <span class="bbp-mark bbp-mark-red">+</span>
          <span class="bbp-line bbp-line-red"></span>
          <span class="bbp-mark bbp-mark-red">+</span>
        </div>

        <div class="bbp-head">● PROJECT BREADBOARD</div>
        <div class="bbp-sub">An interactive breadboard — explore each project as a hardware component.</div>

        <div class="bbp-chips">
          <a class="bbp-chip" href="/projects" style="--chip-bg:#ecfdf5;--chip-name:#16a34a;--led:#16a34a;">
            <span class="bbp-led"></span>
            <span class="bbp-name">PAWSE</span>
            <span class="bbp-tech">Python · MobileBERT · ESP32 · BLE</span>
          </a>
          <a class="bbp-chip" href="/projects" style="--chip-bg:#eef2ff;--chip-name:#4523cb;--led:#4523cb;">
            <span class="bbp-led"></span>
            <span class="bbp-name">ABLEWARE</span>
            <span class="bbp-tech">Python · Raspberry Pi · WebSocket · FastAPI</span>
          </a>
          <a class="bbp-chip" href="/projects" style="--chip-bg:#f5f3ff;--chip-name:#7c3aed;--led:#7c3aed;">
            <span class="bbp-led"></span>
            <span class="bbp-name">ARCTOS 6-DOF</span>
            <span class="bbp-tech">Arduino · C++ · Python · 3D Printing</span>
          </a>
        </div>

        <a href="/projects" class="bbp-cta">VIEW INTERACTIVE BREADBOARD <span>→</span></a>

        <div class="bbp-rail bbp-rail-bottom">
          <span class="bbp-mark bbp-mark-blue">−</span>
          <span class="bbp-line bbp-line-blue"></span>
          <span class="bbp-mark bbp-mark-blue">−</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ABOUT ── -->
  <section id="about" class="border-t border-gray-100 px-8 md:px-20 lg:px-32 py-12 scroll-mt-24">
    <p class="section-label font-mono text-xs tracking-widest mb-6">● ABOUT</p>
    <div class="flex flex-col lg:flex-row gap-12">
      <!-- About text -->
      <div class="lg:w-1/2">
        <h2 class="text-4xl font-bold text-gray-900 mb-6 section-heading">About Me</h2>
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>
            I'm Linh, a Master of Computer Science student at UC Irvine (expected December 2026),
            with a B.S. in Computer Science and Engineering (GPA 3.86). I enjoy building things
            that work — whether that's a full-stack web app, an embedded system, or a trained ML model.
          </p>
          <p>
            My experience spans front-end development with React and TypeScript, back-end APIs with
            Node.js and Flask, embedded C/C++ on microcontrollers like Arduino and Tiva C, and ML
            workflows using PyTorch and Scikit-learn. I've interned at companies in the U.S. and
            Vietnam and done undergraduate research in computational simulation.
          </p>
          <p>
            Outside of coursework I'm Social Chair for the Thai Culture Association at UCI and love
            bringing people together through events and community. I'm currently open to Software
            Engineering and Embedded Systems internship opportunities.
          </p>
        </div>
      </div>

      <!-- Education cards -->
      <div class="lg:w-1/2">
        <h2 class="text-4xl font-bold text-gray-900 mb-6 section-heading">Education</h2>
        <div class="space-y-4">
          {education.map(edu => (
            <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50 shadow-sm">
              <div class="flex items-start justify-between gap-3 mb-1">
                <h3 class="font-semibold text-gray-900 text-base leading-snug">{edu.title}</h3>
                {edu.currentUni && (
                  <span class="shrink-0 text-xs font-medium bg-green-50 text-green-700 border border-green-200 px-2.5 py-0.5 rounded-full">
                    Current
                  </span>
                )}
              </div>
              <p class="text-gray-500 text-sm font-medium mb-1">{edu.school} · {edu.location}</p>
              <p class="text-gray-400 text-xs mb-2">
                {formatDate(edu.startDate)} — {edu.endDate ? formatDate(edu.endDate) : 'Present'}
              </p>
              <p class="text-gray-600 text-sm leading-relaxed">{edu.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED PROJECTS ── -->
  <section id="projects" class="border-t border-gray-100 px-8 md:px-20 lg:px-32 py-12 scroll-mt-24">
    <p class="section-label font-mono text-xs tracking-widest mb-6">● PROJECTS</p>
    <div class="flex items-center justify-between mb-10">
      <h2 class="text-4xl font-bold text-gray-900 section-heading">Featured Projects</h2>
      <a href="/projects" class="text-gray-500 hover:text-gray-900 text-sm font-medium transition-colors">
        View All →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {featuredProjects.map(project => (
        <a
          href={project.href}
          class="flex flex-col p-6 rounded-2xl border border-gray-200 bg-white shadow-sm hover:shadow-md hover:border-gray-400 transition-all"
        >
          <h3 class="font-bold text-gray-900 text-lg mb-2">{project.title}</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4 flex-1">{project.summary}</p>
          <div class="flex flex-wrap gap-1.5">
            {project.tags.map(tag => (
              <span class="px-2 py-0.5 bg-gray-100 text-gray-600 text-xs rounded border border-gray-200">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href="/projects"
        class="inline-flex items-center gap-2 px-6 py-2.5 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors"
      >
        View All Projects →
      </a>
    </div>
  </section>

  <!-- ── EXPERIENCE ── -->
  <section id="experience" class="border-t border-gray-100 px-8 md:px-20 lg:px-32 py-12 scroll-mt-24">
    <p class="section-label font-mono text-xs tracking-widest mb-6">● EXPERIENCE</p>
    <h2 class="text-4xl font-bold text-gray-900 mb-10 section-heading">Experience</h2>

    <div class="relative">
      <!-- Continuous vertical line -->
      <div class="absolute top-4 bottom-4 w-px bg-gray-200 pointer-events-none" style="left:11px;"></div>
      <div class="space-y-6">
        {mainJobs.map(job => (
          <div class="relative" style="padding-left:40px;">
            <!-- Dot on the timeline -->
            <div
              class="absolute rounded-full border-2 border-white shadow z-10"
              style={`width:14px;height:14px;left:5px;top:24px;background:#1a1a2e;`}
            ></div>
            <!-- Connecting dash -->
            <div class="absolute h-px bg-gray-300" style="left:19px;top:31px;width:21px;"></div>
            <!-- Job card -->
            <div
              class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow"
              style={job.currentJob ? "border-left:4px solid #22c55e;" : ""}
            >
              <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
                <div>
                  <h3 class="font-bold text-gray-900 text-lg leading-tight">{job.title}</h3>
                  <p class="text-gray-500 text-sm mt-0.5">{job.company} · {job.location}</p>
                </div>
                <span class="font-mono text-xs px-2.5 py-1 rounded-md shrink-0" style="background:#f0fdf4;color:#22c55e;border:1px solid #bbf7d0;">
                  {formatDate(job.startDate)} — {job.endDate ? formatDate(job.endDate) : 'Present'}
                </span>
              </div>
              <ul class="space-y-1.5">
                {job.goals.map(goal => (
                  <li class="flex gap-2 text-gray-700 text-base leading-relaxed">
                    <span class="flex-shrink-0 mt-0.5" style="color:#9ca3af;">▸</span>
                    {goal}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Extracurriculars -->
    <div class="mt-14">
      <p class="font-mono text-xs tracking-widest mb-2" style="color:#9ca3af;">● EXTRACURRICULARS</p>
      <h3 class="text-xl font-semibold text-gray-700 mb-6">Extracurriculars</h3>
      <div class="relative">
        <div class="absolute top-4 bottom-4 w-px bg-gray-200 pointer-events-none" style="left:11px;"></div>
        <div class="space-y-5">
          {extracurriculars.map(job => (
            <div class="relative" style="padding-left:40px;">
              <div
                class="absolute rounded-full border-2 border-white shadow z-10"
                style="width:12px;height:12px;left:5px;top:20px;background:#9ca3af;"
              ></div>
              <div class="absolute h-px bg-gray-200" style="left:17px;top:26px;width:23px;"></div>
              <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm hover:shadow-md transition-shadow">
                <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
                  <div>
                    <h4 class="font-semibold text-gray-900">{job.title}</h4>
                    <p class="text-gray-500 text-sm mt-0.5">{job.company} · {job.location}</p>
                  </div>
                  <span class="font-mono text-xs px-2.5 py-1 rounded-md shrink-0" style="background:#f9fafb;color:#9ca3af;border:1px solid #e5e7eb;">
                    {formatDate(job.startDate)} — {job.endDate ? formatDate(job.endDate) : 'Present'}
                  </span>
                </div>
                <ul class="space-y-1">
                  {job.goals.map(goal => (
                    <li class="flex gap-2 text-gray-700 text-base leading-relaxed">
                      <span class="flex-shrink-0 mt-0.5" style="color:#d1d5db;">▸</span>
                      {goal}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── SKILLS ── -->
  <section id="skills" class="border-t border-gray-100 px-8 md:px-20 lg:px-32 py-12 scroll-mt-24">
    <p class="section-label font-mono text-xs tracking-widest mb-6">● SKILLS</p>
    <h2 class="text-4xl font-bold text-gray-900 mb-10 section-heading">Skills</h2>

    <div class="flex flex-col gap-5">

      <!-- Programming Languages -->
      <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <div class="sm:w-56 shrink-0">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-relaxed">Programming Languages</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Python','C','C++','Java','JavaScript','TypeScript','HTML','CSS','SQL','Verilog','VHDL','MIPS'].map(s => (
              <span class="px-3 py-1.5 bg-gray-900 text-white text-sm rounded-lg font-medium font-mono">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Frameworks & Libraries -->
      <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <div class="sm:w-56 shrink-0">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-relaxed">Frameworks &amp; Libraries</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Flask','React.js','Node.js','Express.js','EJS','WordPress','PHP','Pandas','Scikit-learn'].map(s => (
              <span class="px-3 py-1.5 bg-white text-gray-800 text-sm rounded-lg font-medium border border-gray-200">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Tools & Technologies -->
      <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <div class="sm:w-56 shrink-0">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-relaxed">Tools &amp; Technologies</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Git','GitHub','PostgreSQL','Postman','Figma','Tiva C','Arduino','Jetson Nano'].map(s => (
              <span class="px-3 py-1.5 bg-white text-gray-800 text-sm rounded-lg font-medium border border-gray-200">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Soft Skills -->
      <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <div class="sm:w-56 shrink-0">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-relaxed">Soft Skills</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {['Team Leadership','Mentorship','Technical Writing','Problem Solving','Cross-functional Collaboration','Public Speaking','Project Management','Adaptability'].map(s => (
              <span class="px-3 py-1.5 text-sm rounded-lg font-medium border" style="background:#f0fdf4;color:#15803d;border-color:#bbf7d0;">{s}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Languages -->
      <div class="p-6 rounded-2xl border border-gray-100 bg-gray-50">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <div class="sm:w-56 shrink-0">
            <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest leading-relaxed">Languages</h3>
          </div>
          <div class="flex flex-wrap gap-4">
            {languages.filter(l => l.show).map(lang => (
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-800">{lang.name}</span>
                <span class="text-xs font-medium text-gray-500 bg-white border border-gray-200 px-2.5 py-0.5 rounded-full">{lang.level}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ── Speech bubble on profile picture ── */
  .speech-bubble {
    position: absolute;
    top: -16px;
    left: 68%;
    background: #1a6b3a;
    color: #fff;
    font-family: 'Courier New', monospace;
    font-size: 16px;
    font-weight: bold;
    letter-spacing: 1px;
    padding: 8px 14px;
    border-radius: 14px;
    border-bottom-left-radius: 4px;
    white-space: nowrap;
    box-shadow: 0 4px 12px rgba(26, 107, 58, 0.3);
    animation: bubble-bob 3s ease-in-out infinite;
    z-index: 10;
  }
  .speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 14px;
    width: 11px;
    height: 11px;
    background: #1a6b3a;
    transform: rotate(45deg);
    border-radius: 2px;
  }
  @keyframes bubble-bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  /* ── Mini-breadboard preview card (mirrors the /projects board palette) ── */
  .bb-preview {
    font-family: 'Courier New', monospace;
    background:
      radial-gradient(#cdc6b4 1.1px, transparent 1.4px) 0 0 / 16px 16px,
      #efeadd;
    border: 1px solid #cfc7b6;
    border-radius: 16px;
    padding: 16px 22px;
    box-shadow: 0 6px 18px rgba(90, 70, 40, 0.10), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }
  .bbp-rail {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .bbp-rail-bottom {
    margin-bottom: 0;
    margin-top: 14px;
  }
  .bbp-line { flex: 1; height: 2.5px; border-radius: 2px; }
  .bbp-line-red { background: #d8281c; }
  .bbp-line-blue { background: #2a5ac4; }
  .bbp-mark { font-weight: bold; font-size: 14px; line-height: 1; }
  .bbp-mark-red { color: #d8281c; }
  .bbp-mark-blue { color: #2a5ac4; }
  .bbp-head {
    font-size: 20px;
    letter-spacing: 3px;
    font-weight: bold;
    color: #1a6b3a;
  }
  .bbp-sub {
    font-size: 16px;
    font-weight: bold;
    color: #8a7a64;
    margin: 4px 0 14px;
  }
  .bbp-chips {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 14px;
  }
 .bbp-chip {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--chip-bg, #f5f3ff);
  border: 1.5px solid rgba(120, 113, 108, 0.25);
  border-radius: 10px;
  padding: 10px 14px;
  text-decoration: none;
  box-shadow: 0 3px 8px rgba(58, 46, 26, 0.12);
  transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
}
  .bbp-chip:hover {
    transform: translateY(-2px);
    border-color: #ee7a23;
    box-shadow: 0 6px 14px rgba(58, 46, 26, 0.3);
  }
  .bbp-led {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--led, #4ade80);
    box-shadow: 0 0 7px var(--led, #4ade80);
    flex-shrink: 0;
  }
  .bbp-name {
    font-weight: bold;
    letter-spacing: 1.5px;
    color: var(--chip-name, #4ade80);
    font-size: 16px;
    flex-shrink: 0;
  }
  .bbp-tech {
    color: #b8b8c0;
    font-size: 14px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bbp-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #ee7a23;
    color: #2b1505;
    font-weight: bold;
    letter-spacing: 2px;
    font-size: 13px;
    padding: 13px 16px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .bbp-cta:hover { background: #e06a12; }

  /* ── Section highlight (existing) ── */
  .section-label {
    color: #aaa;
    transition: color 0.4s ease, text-shadow 0.4s ease;
  }
  section.active .section-label {
    color: #22c55e;
    text-shadow: 0 0 10px rgba(34, 197, 94, 0.4);
  }
  .section-heading {
    position: relative;
    transition: color 0.4s ease;
  }
  .section-heading::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    height: 2px;
    width: 0;
    background: linear-gradient(90deg, #22c55e 0%, rgba(34, 197, 94, 0) 100%);
    transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 1px;
  }
  section.active .section-heading {
    color: #1f2937;
  }
  section.active .section-heading::after {
    width: 140px;
  }
</style>

<script>
  let _scrollHandler: (() => void) | null = null;

  function initSectionHighlight() {
    if (_scrollHandler) {
      window.removeEventListener('scroll', _scrollHandler);
      _scrollHandler = null;
    }

    const SECTION_IDS = ['projects', 'experience', 'skills', 'contact'];

    function setActive(id: string | null) {
      for (const sid of SECTION_IDS) {
        document.getElementById(sid)?.classList.toggle('active', sid === id);
      }
    }

    function getActive(): string | null {
      const vh = window.innerHeight;
      const mid = vh * 0.35;
      let closest: string | null = null;
      let closestDist = Infinity;
      for (const id of SECTION_IDS) {
        const el = document.getElementById(id);
        if (!el) continue;
        const { top, bottom } = el.getBoundingClientRect();
        if (bottom < 80 || top > vh) continue;
        const dist = Math.abs(top - mid);
        if (dist < closestDist) {
          closestDist = dist;
          closest = id;
        }
      }
      return closest;
    }

    setActive(getActive());
    _scrollHandler = () => setActive(getActive());
    window.addEventListener('scroll', _scrollHandler, { passive: true });
  }

  initSectionHighlight();
  document.addEventListener('astro:after-swap', initSectionHighlight);
</script>