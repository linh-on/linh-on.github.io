---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import BackToTop from "../../components/BackToTop.astro";

export async function getStaticPaths() {
    const posts = await getCollection('projects');
    return posts.map(post => ({
        params: { id: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { title, summary, tags, ogImage, url, github, demo, award, status, role, timeline } = post.data;

// Normalize award into an array so a single string or a list both work
const awards = award ? (Array.isArray(award) ? award : [award]) : [];

const { Content, headings } = await render(post);

const tocHeadings = headings.filter(h => h.depth === 2);

// Fallbacks: treat a GitHub `url` as the repo link if `github` isn't set
const githubLink = github ?? (url?.includes("github.com") ? url : undefined);
const liveLink = demo ?? (url && !url.includes("github.com") ? url : undefined);
---

<Layout 
    title={title} 
    description={summary} 
    imageOg={ogImage} 
    scrollSmooth={true}
>
    <!-- ============ Hero (clean, no banner) ============ -->
    <section class="w-full border-b border-blue-lightest bg-white">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-10">

            <!-- Back button -->
            <button
                onclick="history.back()"
                class="inline-flex items-center gap-2 px-4 py-2 mb-8 rounded-full border border-n300 text-n500 hover:text-n600 hover:border-n500 hover:bg-n100 transition-all duration-200 text-sm font-medium"
            >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                    <path d="M7.82843 10.9999H20V12.9999H7.82843L13.1924 18.3638L11.7782 19.778L4 11.9999L11.7782 4.22168L13.1924 5.63589L7.82843 10.9999Z" />
                </svg>
                Back
            </button>

            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-tight mb-4" style="color:#1a1a1a;">
                {title}
            </h1>

            <p class="text-base md:text-lg text-n500 leading-relaxed max-w-3xl mb-5">
                {summary}
            </p>

            {awards.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-5">
                    {awards.map(a => (
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-amber-50 text-amber-800 border border-amber-300 text-sm font-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-amber-500 flex-shrink-0">
                                <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                            </svg>
                            {a}
                        </span>
                    ))}
                </div>
            )}

            <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-md bg-blue-lightest text-primary-light border border-blue-light/50">
                        <span class="w-1.5 h-1.5 rounded-full bg-primary-light flex-shrink-0"></span>
                        {tag}
                    </span>
                ))}
            </div>
        </div>
    </section>

    <!-- ============ Body ============ -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-14">

            <!-- Main content -->
            <div class="lg:col-span-2 min-w-0">

                <!-- Demo media placeholder.
                     Replace this block with an <Image /> or <video> when assets are ready, e.g.:
                     <Image src={demoImage} alt={`${title} demo`} class="rounded-xl border border-blue-lightest shadow-sm mb-10" />
                     or
                     <video src="/videos/demo.mp4" controls class="rounded-xl border border-blue-lightest shadow-sm mb-10 w-full"></video>
                -->
                <div class="mb-10 rounded-xl border-2 border-dashed border-blue-lightest dark:border-blue-dark/40 bg-blue-lightest/15 dark:bg-primary-dark/5 flex flex-col items-center justify-center py-16 px-6 text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-10 h-10 text-blue-light mb-3">
                        <rect x="3" y="5" width="18" height="14" rx="2"/>
                        <polygon points="10 9 15 12 10 15" fill="currentColor" stroke="none"/>
                    </svg>
                    <p class="text-sm font-medium text-n500 dark:text-n200">Demo coming soon</p>
                </div>

                <!-- Table of Contents -->
                {tocHeadings.length > 0 && (
                    <div class="mb-10 rounded-xl border border-blue-lightest dark:border-blue-dark/40 bg-blue-lightest/25 dark:bg-primary-dark/10 px-5 py-4">
                        <p class="text-xs font-semibold uppercase tracking-widest text-primary-light dark:text-primary-dark mb-3">
                            Contents
                        </p>

                        <ul class="space-y-0.5">
                            {tocHeadings.map(h => (
                                <li>
                                    <a
                                        href={`#${h.slug}`}
                                        class="toc-link text-sm text-n500 dark:text-n200 hover:text-primary-light dark:hover:text-primary-dark py-1 inline-block transition-colors duration-150"
                                    >
                                        {h.text}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}

                <!-- MDX article -->
                <article id="article" class="prose dark:prose-invert max-w-none w-full">
                    <Content />
                </article>

                <BackToTop />
            </div>

            <!-- Sticky sidebar -->
            <aside class="lg:col-span-1">
                <div class="lg:sticky lg:top-24 space-y-5">

                    <!-- Recognition (standout card) -->
                    {awards.length > 0 && (
                        <div class="rounded-xl border border-amber-300 bg-gradient-to-br from-amber-50 to-yellow-50 p-5 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-widest text-amber-700 mb-3 flex items-center gap-1.5">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                </svg>
                                Recognition
                            </p>
                            <ul class="space-y-2">
                                {awards.map(a => (
                                    <li class="text-sm font-semibold text-amber-900 leading-relaxed flex items-start gap-1.5">
                                        <span class="text-amber-500 mt-0.5 flex-shrink-0">&#9733;</span>
                                        <span>{a}</span>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    )}

                    <!-- Links: live demo + GitHub -->
                    {(liveLink || githubLink) && (
                        <div class="rounded-xl border border-blue-lightest dark:border-blue-dark/40 bg-white p-5 shadow-sm space-y-3">
                            {liveLink && (
                                <a
                                    href={liveLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg bg-primary-light hover:bg-primary-hover-light dark:bg-blue-medium dark:hover:bg-blue-dark text-white font-semibold text-sm transition-colors duration-200"
                                >
                                    Visit the Project
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
                                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                        <polyline points="15 3 21 3 21 9" />
                                        <line x1="10" y1="14" x2="21" y2="3" />
                                    </svg>
                                </a>
                            )}

                            {githubLink && (
                                <a
                                    href={githubLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="flex items-center justify-center gap-2 w-full px-4 py-3 rounded-lg border border-n300 hover:border-n500 text-n600 hover:bg-n100 font-semibold text-sm transition-colors duration-200"
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
                                        <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.09.68-.22.68-.49 0-.24-.01-.88-.01-1.73-2.78.62-3.37-1.37-3.37-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.57 2.34 1.12 2.91.85.09-.66.35-1.12.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.36 9.36 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.06 10.06 0 0 0 22 12.25C22 6.58 17.52 2 12 2z"/>
                                    </svg>
                                    View on GitHub
                                </a>
                            )}
                        </div>
                    )}

                    <!-- Project facts -->
                    {(role || timeline || status) && (
                        <div class="rounded-xl border border-blue-lightest dark:border-blue-dark/40 bg-white p-5 shadow-sm">
                            <p class="text-xs font-semibold uppercase tracking-widest text-n500 dark:text-n200 mb-4">
                                Project Info
                            </p>
                            <dl class="space-y-3 text-sm">
                                {role && (
                                    <div>
                                        <dt class="text-xs text-n400 uppercase tracking-wide mb-0.5">Role</dt>
                                        <dd class="font-medium text-n600">{role}</dd>
                                    </div>
                                )}
                                {timeline && (
                                    <div>
                                        <dt class="text-xs text-n400 uppercase tracking-wide mb-0.5">Timeline</dt>
                                        <dd class="font-medium text-n600">{timeline}</dd>
                                    </div>
                                )}
                                {status && (
                                    <div>
                                        <dt class="text-xs text-n400 uppercase tracking-wide mb-0.5">Status</dt>
                                        <dd class="font-medium text-n600">{status}</dd>
                                    </div>
                                )}
                            </dl>
                        </div>
                    )}

                    <!-- Tech stack tags -->
                    <div class="rounded-xl border border-blue-lightest dark:border-blue-dark/40 bg-white p-5 shadow-sm">
                        <p class="text-xs font-semibold uppercase tracking-widest text-n500 dark:text-n200 mb-4">
                            Tech Stack
                        </p>

                        <div class="flex flex-wrap gap-2">
                            {tags.map(tag => (
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-md bg-blue-lightest dark:bg-primary-dark/20 text-primary-light dark:text-primary-dark border border-blue-light/50 dark:border-primary-dark">
                                    <span class="w-1.5 h-1.5 rounded-full bg-primary-light dark:bg-primary-dark flex-shrink-0"></span>
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>

                </div>
            </aside>
        </div>
    </div>
</Layout>

<style is:global>
    #article h2 {
        @apply text-2xl font-bold tracking-tight mt-10 mb-4 pb-2 border-b border-blue-lightest;
        scroll-margin-top: 6rem;
    }

    #article h3 {
        @apply text-xl font-semibold tracking-tight mt-6 mb-3;
        scroll-margin-top: 6rem;
    }

    .toc-link:hover {
        transform: translateX(4px);
    }
</style>