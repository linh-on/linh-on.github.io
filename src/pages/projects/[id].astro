
---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import BackBtn from "@/components/BackBtn.astro";
import BackToTop from "../../components/BackToTop.astro";

export async function getStaticPaths() {
    const posts = await getCollection('projects');
    return posts.map(post => ({
        params: { id: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { title, summary, tags, cover, ogImage, url } = post.data;

const { Content } = await render(post);

---
<Layout title={title} description={summary} imageOg={ogImage} scrollSmooth={true}>
    <>
        <div class="flex justify-center mt-10">
            <BackBtn/>
        </div>
        <div class="w-full flex flex-col gap-4">
            <h1 class="text-3xl font-bold">{title}</h1>
            <div class="flex flex-wrap gap-2">
                {tags.map(tag => (
                    <span class="px-3 py-1 text-xs font-medium rounded-full bg-blue-lightest dark:bg-primary-dark/20 text-primary-light dark:text-primary-dark border border-blue-light dark:border-primary-dark">
                        {tag}
                    </span>
                ))}
            </div>
        </div>
        {cover && (
            <Image
                transition:name={`${post.id}-image`}
                class="rounded-2xl w-full max-h-[300px] object-cover object-top"
                src={cover}
                alt="Main project image"
            />
        )}
        <p class="text-n500 dark:text-n200">{summary}</p>
        {url && (
            <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-primary-light hover:bg-primary-hover-light dark:bg-blue-medium dark:hover:bg-blue-dark text-white font-medium transition-colors w-fit"
            >
                Visit the project ↗
            </a>
        )}

        <article id="article" class="mt-8 prose dark:prose-invert max-w-none w-full">
            <Content/>
        </article>
        <BackToTop />
    </>
</Layout>

<style is:global>
    h2 {
        @apply text-2xl font-bold my-4;
    }
</style>

