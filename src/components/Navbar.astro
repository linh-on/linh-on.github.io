---
import {menu} from "../data/menu";
import {SITE} from "../config";

const pathname = Astro.url.pathname;
const isHomePage = pathname === '/';

// For page-based links (not hash anchors), determine active state server-side
function isPageActive(href: string): boolean {
  if (href.startsWith('/#') || href === '/') return false; // handled by scroll JS
  return pathname.startsWith(href);
}

// Section ID extracted from hash links (e.g. "/#about" → "about", "/" → "top")
function getSectionId(href: string): string | null {
  if (href === '/') return 'top';
  if (href.startsWith('/#')) return href.slice(2);
  return null;
}
---

<nav class="fixed w-full z-20 top-0 left-0" style="background:#0f0f1a;border-bottom:1px solid #1a1a2e;" id="menu">
  <div class="w-full px-8 md:px-20 lg:px-32 py-5" style="display:grid;grid-template-columns:auto 1fr auto;align-items:center;">

    <!-- Left: logo -->
    <a href="/" class="flex items-center" style="text-decoration:none;gap:16px;margin-left:-16px;">
      <span class="pulse-dot rounded-full flex-shrink-0" style="background:#22c55e;display:inline-block;width:10px;height:10px;"></span>
      <div>
        <div style="color:#ffffff;font-weight:700;font-family:'Courier New',monospace;font-size:20px;letter-spacing:2px;line-height:1.25;">LINH ON</div>
        <div class="hidden md:block" style="color:#22c55e;font-family:'Courier New',monospace;font-size:14px;letter-spacing:0.5px;line-height:1.25;white-space:nowrap;">Software Engineer &amp; Embedded Systems Engineer</div>
      </div>
    </a>

    <!-- Center: nav links (laptop and wider only; tablets use the hamburger) -->
    <div class="hidden xl:flex items-center justify-center" id="navbar-sticky">
      <ul class="flex items-center m-0 p-0" style="list-style:none;gap:32px;">
        {menu.map(item => {
          const sectionId = getSectionId(item.href);
          const pageActive = isPageActive(item.href);
          // Section links: only active server-side if NOT on home page (JS handles home page)
          // Page links: active based on pathname
          const initialActive = pageActive || (sectionId === 'top' && isHomePage);
          return (
            <li>
              <a
                href={item.href}
                class={`font-mono transition-colors ${initialActive ? 'nav-active' : 'nav-inactive'}`}
                style="font-size:14px;letter-spacing:1.5px;"
                data-section={sectionId ?? undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Right: hamburger on mobile, empty spacer on desktop -->
    <div class="flex justify-end">
      <button id="btn-menu" type="button"
        class="inline-flex items-center justify-center p-2 w-9 h-9 rounded-lg xl:hidden focus:outline-none"
        style="color:#888;"
        aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile dropdown -->
  <div class="hidden xl:hidden w-full" id="navbar-mobile" style="background:#0f0f1a;border-top:1px solid #1a1a2e;">
    <ul class="flex flex-col p-4 m-0" style="list-style:none;gap:12px;">
      {menu.map(item => {
        const sectionId = getSectionId(item.href);
        const pageActive = isPageActive(item.href);
        const initialActive = pageActive || (sectionId === 'top' && isHomePage);
        return (
          <li>
            <a
              href={item.href}
              class={`block font-mono transition-colors ${initialActive ? 'nav-active' : 'nav-inactive'}`}
              style="font-size:14px;letter-spacing:1.5px;"
              data-section={sectionId ?? undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</nav>

<style>
  @keyframes navpulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .pulse-dot {
    animation: navpulse 2s ease-in-out infinite;
  }
  .nav-inactive {
    color: #cccccc;
  }
  .nav-inactive:hover {
    color: #ffffff;
  }
  .nav-active {
    color: #22c55e;
  }
  .nav-active:hover {
    color: #22c55e;
  }
</style>

<script>
  const SECTION_IDS = ['projects', 'experience', 'skills', 'contact'];

  function setActiveSection(sectionId: string | null) {
    document.querySelectorAll('[data-section]').forEach(link => {
      const s = (link as HTMLElement).dataset.section;
      const isActive = s === sectionId;
      link.classList.toggle('nav-active', isActive);
      link.classList.toggle('nav-inactive', !isActive);
    });
  }

  function getActiveSection(): string {
    const threshold = window.innerHeight * 0.5;
    let current = 'top';
    for (const id of SECTION_IDS) {
      const el = document.getElementById(id);
      if (el && el.getBoundingClientRect().top <= threshold) {
        current = id;
      }
    }
    return current;
  }

  function initScrollSpy() {
    if (window.location.pathname !== '/') return;
    setActiveSection(getActiveSection());
    window.addEventListener('scroll', () => setActiveSection(getActiveSection()), { passive: true });
  }

  function initNav() {
    const btn = document.getElementById('btn-menu');
    const mobileNav = document.getElementById('navbar-mobile');
    btn?.addEventListener('click', () => {
      mobileNav?.classList.toggle('hidden');
    });
    initScrollSpy();
  }

  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
