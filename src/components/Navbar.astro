---
import {menu} from "../data/menu";
import {SITE} from "../config";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  if (href.startsWith('/#')) return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="fixed w-full z-20 top-0 left-0" style="background:#0f0f1a;border-bottom:1px solid #1a1a2e;" id="menu">
  <div class="flex items-center justify-between w-full px-8 py-4">

    <!-- Left: logo -->
    <a href="/" class="flex items-center gap-3" style="text-decoration:none;">
      <span class="pulse-dot w-2.5 h-2.5 rounded-full flex-shrink-0" style="background:#22c55e;display:inline-block;"></span>
      <div>
        <div style="color:#ffffff;font-weight:700;font-family:'Courier New',monospace;font-size:1rem;letter-spacing:0.15em;line-height:1.2;">LINH ON</div>
        <div style="color:#666;font-family:'Courier New',monospace;font-size:10px;line-height:1.2;">Software Engineer &amp; Embedded Systems Engineer</div>
      </div>
    </a>

    <!-- Mobile hamburger -->
    <button id="btn-menu" type="button"
      class="inline-flex items-center justify-center p-2 w-9 h-9 rounded-lg md:hidden focus:outline-none"
      style="color:#888;"
      aria-expanded="false">
      <span class="sr-only">Open main menu</span>
      <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
      </svg>
    </button>

    <!-- Nav links -->
    <div class="items-center hidden w-full md:flex md:w-auto" id="navbar-sticky">
      <ul class="flex flex-col md:flex-row md:gap-8 mt-4 md:mt-0 w-full md:w-auto p-4 md:p-0 border border-gray-800 rounded-lg md:border-0" style="background:#0f0f1a;">
        {menu.map(item => (
          <li>
            <a
              href={item.href}
              class={`block py-2 md:py-0 font-mono text-xs tracking-widest uppercase transition-colors ${isActive(item.href) ? 'nav-active' : 'nav-inactive'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>
</nav>

<style>
  @keyframes navpulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .pulse-dot {
    animation: navpulse 2s ease-in-out infinite;
  }
  .nav-inactive {
    color: #aaa;
  }
  .nav-inactive:hover {
    color: #ffffff;
  }
  .nav-active {
    color: #22c55e;
  }
  .nav-active:hover {
    color: #22c55e;
  }
</style>

<script>
  function initNav() {
    const btn = document.getElementById('btn-menu');
    const navbar = document.getElementById('navbar-sticky');
    btn?.addEventListener('click', () => {
      navbar?.classList.toggle('hidden');
    });
  }
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
