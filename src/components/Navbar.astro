---
import {menu} from "../data/menu";
import {SITE} from "../config";

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  if (href.startsWith('/#')) return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="fixed w-full z-20 top-0 left-0" style="background:#0f0f1a;border-bottom:1px solid #1a1a2e;" id="menu">
  <div class="w-full px-10 py-5" style="display:grid;grid-template-columns:1fr auto 1fr;align-items:center;">

    <!-- Left: logo -->
    <a href="/" class="flex items-center" style="text-decoration:none;gap:10px;">
      <span class="pulse-dot rounded-full flex-shrink-0" style="background:#22c55e;display:inline-block;width:10px;height:10px;"></span>
      <div>
        <div style="color:#ffffff;font-weight:700;font-family:'Courier New',monospace;font-size:16px;letter-spacing:2px;line-height:1.2;">LINH ON</div>
        <div style="color:#22c55e;font-family:'Courier New',monospace;font-size:11px;letter-spacing:0.5px;line-height:1.2;">Software Engineer &amp; Embedded Systems Engineer</div>
      </div>
    </a>

    <!-- Center: nav links (desktop only) -->
    <div class="hidden md:flex items-center justify-center" id="navbar-sticky">
      <ul class="flex items-center m-0 p-0" style="list-style:none;gap:32px;">
        {menu.map(item => (
          <li>
            <a
              href={item.href}
              class={`font-mono transition-colors ${isActive(item.href) ? 'nav-active' : 'nav-inactive'}`}
              style="font-size:12px;letter-spacing:1.5px;"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Right: hamburger on mobile, empty spacer on desktop -->
    <div class="flex justify-end">
      <button id="btn-menu" type="button"
        class="inline-flex items-center justify-center p-2 w-9 h-9 rounded-lg md:hidden focus:outline-none"
        style="color:#888;"
        aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile dropdown -->
  <div class="hidden md:hidden w-full" id="navbar-mobile" style="background:#0f0f1a;border-top:1px solid #1a1a2e;">
    <ul class="flex flex-col p-4 m-0" style="list-style:none;gap:12px;">
      {menu.map(item => (
        <li>
          <a
            href={item.href}
            class={`block font-mono transition-colors ${isActive(item.href) ? 'nav-active' : 'nav-inactive'}`}
            style="font-size:12px;letter-spacing:1.5px;"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  @keyframes navpulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .pulse-dot {
    animation: navpulse 2s ease-in-out infinite;
  }
  .nav-inactive {
    color: #cccccc;
  }
  .nav-inactive:hover {
    color: #ffffff;
  }
  .nav-active {
    color: #22c55e;
  }
  .nav-active:hover {
    color: #22c55e;
  }
</style>

<script>
  function initNav() {
    const btn = document.getElementById('btn-menu');
    const mobileNav = document.getElementById('navbar-mobile');
    btn?.addEventListener('click', () => {
      mobileNav?.classList.toggle('hidden');
    });
  }
  initNav();
  document.addEventListener('astro:after-swap', initNav);
</script>
