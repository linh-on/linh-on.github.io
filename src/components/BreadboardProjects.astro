      <div id="p-detail-view" style="display:none;flex-direction:column;height:100%">
        <div class="panel-hdr" id="panel-hdr-content"></div>
        <div class="panel-body" id="panel-body-content"></div>
      </div>
    </div>
  </div>
</div>
