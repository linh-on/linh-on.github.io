<script is:inline>
// @ts-nocheck
function initBreadboard() {
const NS='http://www.w3.org/2000/svg';

// Set to true to have the board already powered on when the page loads.
const POWER_ON_AT_START=false;

/*
 CIRCUIT TOPOLOGY:
   SUPPLY ──[POWER push switch, top-right corner]──> +RAIL
   +RAIL ──> D1 power-indicator LED ──> R1 current-limiting resistor (lit only when switched on)
   +RAIL ──> PAWSE (MCU / brain)
   DEEP DIABETES (analog sensor) ──SIGNAL──> PAWSE
   OBSTACLE BOT (ToF sensor board) ──I2C DATA──> PAWSE (bused through center channel)
   PAWSE ──DATA+CLK──> ABLEWARE (display module)
   PAWSE ──PWM──> ARCTOS (motor driver)
   ABLEWARE ──> DRAMA TRACKER (memory IC) ──> SPIDER (coprocessor)
   GND rail ──> OBSTACLE BOT
 When the switch is OFF, nothing downstream has power: wires read dead,
 silkscreen text is dark, status LEDs are unlit, and chips don't respond to clicks.
*/

const PROJECTS=[
  {id:'pawse',name:'PAWSE',subtitle:'Smart Notification Classifier',bg:'#1b1b1f',border:'#16a34a',label:'#4ade80',icon:'🐾',x:40,y:28,w:250,h:122,pins:5,shape:'ic',tech:['Python','MobileBERT','ESP32','React Native','BLE','Supabase'],desc:'A phone lockbox that physically locks your phone during focus sessions, with AI-powered notification filtering.',highlights:['95%+ MobileBERT classifier accuracy','BLE hardware-software bridge','FreeRTOS firmware on ESP32','School mode with roster polling'],awards:['Semifinalist — UCI Stella Zhang New Venture Competition','Semifinalist — Beall & Butterworth 2026'],github:'https://github.com/linh-on/pawse',page:'/projects/pawse'},
  {id:'ableware',name:'ABLEWARE',subtitle:'Assistive Lift System',bg:'#11301c',border:'#1d4ed8',label:'#6ee7a0',icon:'♿',x:340,y:32,w:230,h:115,pins:5,shape:'display',tech:['Python','Raspberry Pi','Arduino','WebSocket','FastAPI','TypeScript'],desc:'Voice-controlled assistive lift. A Pi listens for wake words and sends commands over WebSocket to a hub coordinating hardware and simulation.',highlights:['Wake word + Vosk voice pipeline','WebSocket hub architecture','PyBullet 3D simulation','React/TypeScript dashboard'],awards:['2nd Place — 2026 UCI MCS ICS Expo'],github:'https://github.com/EliyaKhajeiee/ableware-pi-final',page:'/projects/ableware'},
  {id:'drama',name:'DRAMA TRACKER',subtitle:'Movie Web App',bg:'#231c0e',border:'#b45309',label:'#fcd34d',icon:'🎬',x:630,y:40,w:200,h:92,pins:3,shape:'ic',tech:['React.js','Node.js','PostgreSQL','Python','Flask','TMDB API'],desc:'Full-stack movie tracking app with a content-based filtering recommendation engine using TF-IDF cosine similarity.',highlights:['TF-IDF content filtering','TMDB API integration','Flask recommendation service','Vercel + Render deployed'],awards:[],github:'https://github.com/linh-on/drama-tracker',page:'/projects/drama-tracker'},
  {id:'diabetes',name:'DEEP DIABETES',subtitle:'Risk Prediction Model',bg:'#16335e',border:'#0e7490',label:'#7dd3fc',icon:'🧬',x:40,y:250,w:200,h:92,pins:3,shape:'sensor',tech:['Python','PyTorch','Scikit-learn','Pandas','NumPy'],desc:'Deep MLP for diabetes risk prediction on CDC BRFSS 2015 data, outperforming baseline classifiers.',highlights:['Weighted BCE for imbalance','AdamW + CosineAnnealing LR','Early stopping on ROC-AUC','Feature ablation analysis'],awards:[],github:'https://github.com/juliethecao/deep-diabetes-risk',page:'/projects/deep-diabetes-risk'},
  {id:'obstacle',name:'OBSTACLE BOT',subtitle:'Autonomous Avoidance Vehicle',bg:'#8f2424',border:'#b91c1c',label:'#ffe3c2',icon:'🚗',x:290,y:250,w:210,h:92,pins:3,shape:'sensor',tech:['Arduino','C++','VL53L1X ToF','TCA9548A','DRV8835'],desc:'Arduino-based autonomous vehicle that navigates around obstacles using time-of-flight distance sensors and differential drive motors.',highlights:['VL53L1X ToF sensor array','TCA9548A I2C multiplexer','DRV8835 motor driver control','Real-time avoidance logic'],awards:[],github:'https://github.com/linh-on',page:'/projects/obstacle-avoidance-vehicle'},
  {id:'arctos',name:'ARCTOS 6-DOF',subtitle:'Robotic Arm',bg:'#1e1a2e',border:'#7c3aed',label:'#c4b5fd',icon:'🦾',x:560,y:250,w:200,h:92,pins:3,shape:'ic',tech:['Arduino','C++','Python','Arctos Studio','3D Printing'],desc:'6-DOF robotic arm using Arduino MEGA coordinating stepper motors across all joints for competition tasks.',highlights:['6-joint stepper motor control','Custom CAD end-effector','Waypoint programming','Cup stacking & weight lift'],awards:[],github:'https://github.com/linh-on',page:'/projects/arctos-robotic-arm'},
  {id:'spider',name:'SPIDER DROID',subtitle:'Autonomous Robot',bg:'#241313',border:'#b91c1c',label:'#fca5a5',icon:'🕷️',x:810,y:250,w:170,h:92,pins:3,shape:'ic',tech:['Python','PyTorch','PPO','Jetson Nano','LiDAR'],desc:'3D-printed spider robot trained with PPO RL to walk autonomously across varied terrain, deployed on Jetson Nano.',highlights:['PPO reinforcement learning','LiDAR obstacle detection','Jetson Nano deployment','No external compute'],awards:[],github:'https://github.com/linh-on',page:'/projects/ai-spider-droid'},
];

/*
 Straight Manhattan-routed jumpers. Bus wires share the center channel on
 separate lanes so nothing crosses. All of these are DOWNSTREAM of the power
 switch, so they dim when the system is off.
*/
const WIRES=[
  {pts:[[962,2],[962,8]],           color:'#d8281c'}, // supply -> POWER switch
  {pts:[[927,26],[943,26]],         color:'#d8281c'}, // switch -> D1 power indicator
  {pts:[[80,2],[80,28]],            color:'#d8281c'}, // VCC: top rail -> MCU
  {pts:[[400,378],[400,346]],       color:'#2e2e32'}, // GND: bottom rail -> obstacle board
  {pts:[[140,250],[140,150]],       color:'#2563eb'}, // SIGNAL: diabetes sensor -> MCU
  {pts:[[395,250],[395,188],[200,188],[200,150]], color:'#e8a013'}, // I2C DATA: obstacle -> MCU (channel lane 2)
  {pts:[[255,150],[255,181],[600,181],[600,250]], color:'#f47b20'}, // PWM: MCU -> motor driver (channel lane 1)
  {pts:[[290,100],[340,100]],       color:'#22a04a'}, // DATA: MCU -> display
  {pts:[[290,114],[340,114]],       color:'#2563eb'}, // CLK:  MCU -> display
  {pts:[[570,48],[630,48]],         color:'#0ea5b7'}, // BUS: display -> memory IC
  {pts:[[820,132],[820,250]],       color:'#c89b2a'}, // ADDR: memory IC -> coprocessor
];

let zoom=1,selected=null,blinkT=[],powerOn=true;
const svg=document.getElementById('bbsvg');
if(!svg) return;
const pMap={};PROJECTS.forEach(p=>pMap[p.id]=p);

function el(tag,a={}){const e=document.createElementNS(NS,tag);for(const[k,v]of Object.entries(a))e.setAttribute(k,v);return e;}
function tx(s,a={}){const e=el('text',a);e.textContent=s;return e;}

/* ---------- BOARD SURFACE ---------- */
const defs=el('defs');
const pat=el('pattern',{id:'h',width:14.5,height:17,patternUnits:'userSpaceOnUse'});
pat.appendChild(el('circle',{cx:7,cy:8,r:2.4,fill:'#cdc6b4'}));
pat.appendChild(el('rect',{x:5.6,y:6.6,width:2.8,height:2.8,rx:0.6,fill:'#5a564c'}));
defs.appendChild(pat);
const f=el('filter',{id:'cshadow',x:'-20%',y:'-20%',width:'140%',height:'140%'});
f.appendChild(el('feDropShadow',{dx:'2',dy:'3',stdDeviation:'2.5','flood-color':'#3a2e1a','flood-opacity':'0.3'}));
defs.appendChild(f);
svg.appendChild(defs);

svg.appendChild(el('rect',{width:1000,height:380,fill:'#efeadd'}));
svg.appendChild(el('rect',{width:1000,height:380,fill:'url(#h)'}));
svg.appendChild(el('rect',{x:0,y:176,width:1000,height:16,fill:'#e2dcca'}));
svg.appendChild(el('line',{x1:0,y1:176,x2:1000,y2:176,stroke:'#c6bfa9','stroke-width':1}));
svg.appendChild(el('line',{x1:0,y1:192,x2:1000,y2:192,stroke:'#fbf8ef','stroke-width':1}));

['rt','rb'].forEach(id=>{const r=document.getElementById(id);if(!r)return;for(let i=0;i<60;i++){const d=document.createElement('div');d.className='rdot';r.appendChild(d);}});

'ABCDEFGHIJ'.split('').forEach((l,i)=>{
  svg.appendChild(tx(l,{x:4,y:28+i*17,fill:'#9a9280','font-size':9,'font-family':'monospace'}));
});
for(let i=1;i<=68;i++){
  if(i%5===0)svg.appendChild(tx(String(i),{x:14+i*14.5,y:13,fill:'#9a9280','font-size':8,'font-family':'monospace','text-anchor':'middle'}));
}

/* ---------- STRAIGHT JUMPER WIRES ---------- */
const wireG=el('g');
function routeD(pts,r=6){
  let d=`M${pts[0][0]},${pts[0][1]}`;
  for(let i=1;i<pts.length-1;i++){
    const [px,py]=pts[i-1],[cx,cy]=pts[i],[nx,ny]=pts[i+1];
    const inL=Math.hypot(cx-px,cy-py),outL=Math.hypot(nx-cx,ny-cy);
    const rr=Math.min(r,inL/2,outL/2);
    const ax=cx-(cx-px)/inL*rr, ay=cy-(cy-py)/inL*rr;
    const bx=cx+(nx-cx)/outL*rr, by=cy+(ny-cy)/outL*rr;
    d+=` L${ax},${ay} Q${cx},${cy} ${bx},${by}`;
  }
  const last=pts[pts.length-1];
  d+=` L${last[0]},${last[1]}`;
  return d;
}
WIRES.forEach(w=>{
  const d=routeD(w.pts);
  wireG.appendChild(el('path',{d,stroke:'#3a2e1a',opacity:0.15,'stroke-width':4.4,fill:'none','stroke-linecap':'round','stroke-linejoin':'round',transform:'translate(1.4,2.2)'}));
  wireG.appendChild(el('path',{d,stroke:w.color,'stroke-width':3.4,fill:'none','stroke-linecap':'round','stroke-linejoin':'round'}));
  wireG.appendChild(el('path',{d,stroke:'#ffffff',opacity:0.38,'stroke-width':1,fill:'none','stroke-linecap':'round',transform:'translate(-0.5,-0.8)'}));
  [w.pts[0],w.pts[w.pts.length-1]].forEach(([px,py])=>{
    wireG.appendChild(el('circle',{cx:px,cy:py,r:2.3,fill:'#9c9c9c',stroke:'#6e6e6e','stroke-width':0.6}));
  });
});
svg.appendChild(wireG);

/* ---------- POWER INDICATOR CIRCUIT: POWER switch -> D1 -> R1 ---------- */
function desig(x,y,label){svg.appendChild(tx(label,{x,y,'font-size':6.5,'font-family':'monospace',fill:'#8a8273','text-anchor':'middle'}));}

// R1 current-limiting resistor
(function(){
  const g=el('g',{transform:'translate(868,22)'});
  g.appendChild(el('line',{x1:-26,y1:0,x2:26,y2:0,stroke:'#9c9c9c','stroke-width':1.6,'stroke-linecap':'round'}));
  g.appendChild(el('rect',{x:-15,y:-5,width:30,height:10,rx:5,fill:'#d9b38c',stroke:'#b98e60','stroke-width':0.8,filter:'url(#cshadow)'}));
  [['#7a3b12',-9],['#1a1a1a',-3],['#d8281c',3],['#c89b2a',9]].forEach(([c,bx])=>{
    g.appendChild(el('rect',{x:bx-1.4,y:-5,width:2.8,height:10,fill:c,opacity:0.9}));
  });
  svg.appendChild(g);
})();
desig(868,38,'R1');

// D1 power LED (lit only when switched on)
const d1G=el('g',{transform:'translate(918,20)'});
const d1Glow=el('circle',{cx:0,cy:0,r:11,fill:'#ff5b3a'});
d1Glow.style.opacity=0;
d1G.appendChild(d1Glow);
d1G.appendChild(el('line',{x1:-3,y1:4,x2:-3,y2:14,stroke:'#9c9c9c','stroke-width':1.4}));
d1G.appendChild(el('line',{x1:3,y1:4,x2:3,y2:12,stroke:'#9c9c9c','stroke-width':1.4}));
const d1Dome=el('path',{d:'M-6,4 L-6,-2 A6,6 0 0,1 6,-2 L6,4 Z',fill:'#7a2a22',stroke:'#00000022','stroke-width':0.6,filter:'url(#cshadow)'});
d1G.appendChild(d1Dome);
d1G.appendChild(el('circle',{cx:-1.8,cy:-2.5,r:1.6,fill:'#fff',opacity:0.7}));
svg.appendChild(d1G);
desig(918,46,'D1');

// POWER push switch — round latching power button, top-right corner
const swG=el('g',{transform:'translate(962,26)'});
swG.style.cursor='pointer';
const swGlow=el('circle',{r:24,fill:'#2aa84a'});
swGlow.style.opacity=0;
swG.appendChild(swGlow);
swG.appendChild(el('circle',{r:18,fill:'#c4c4c8',stroke:'#8a8a8e','stroke-width':1.2,filter:'url(#cshadow)'}));
swG.appendChild(el('circle',{r:14.5,fill:'#dcdce0',stroke:'#aaaaae','stroke-width':0.7}));
const swRing=el('circle',{r:11.8,fill:'none',stroke:'#4a4a4e','stroke-width':2});
swG.appendChild(swRing);
const swCap=el('circle',{r:9.6,fill:'#2e2e32',stroke:'#1a1a1c','stroke-width':0.7});
swG.appendChild(swCap);
swG.appendChild(el('circle',{cx:-2.8,cy:-3.2,r:2.6,fill:'#fff',opacity:0.12}));
const swSym=el('g',{stroke:'#88888c','stroke-width':1.9,fill:'none','stroke-linecap':'round'});
swSym.appendChild(el('path',{d:'M-4.2,-3.4 A5.8,5.8 0 1 0 4.2,-3.4'}));
swSym.appendChild(el('line',{x1:0,y1:-7,x2:0,y2:-0.8}));
swG.appendChild(swSym);
swG.addEventListener('mousedown',()=>swCap.setAttribute('r','8.8'));
swG.addEventListener('mouseup',()=>swCap.setAttribute('r','9.6'));
swG.addEventListener('mouseleave',()=>swCap.setAttribute('r','9.6'));
swG.addEventListener('click',togglePower);
svg.appendChild(swG);
svg.appendChild(tx('POWER',{x:962,y:54,'font-size':7.5,'font-family':'monospace',fill:'#8a8273','text-anchor':'middle','font-weight':'bold','letter-spacing':1}));

// boot instruction shown on the board while the system is off
const hintT=tx('⏻  SYSTEM OFF! PLEASE PRESS THE POWER SWITCH TO BOOT',{x:500,y:190,'text-anchor':'middle','font-size':20,'font-weight':'bold','font-family':'Courier New,monospace',fill:'#6b5b45','letter-spacing':2});
hintT.style.paintOrder='stroke';
hintT.setAttribute('stroke','#efeadd');
hintT.setAttribute('stroke-width','6');
hintT.style.opacity=0;
svg.appendChild(hintT);

/* ---------- PROJECT COMPONENTS ---------- */
PROJECTS.forEach(p=>{
  const g=el('g',{transform:`translate(${p.x},${p.y})`});
  g.style.cursor='pointer';
  const W=p.w,H=p.h;
  const subFill=p.shape==='ic'?'#b8b8c0':'#ece4d4';
  const techFill=p.shape==='ic'?'#8e8e98':'#d2c6b0';

  if(p.shape==='sensor'){
    const strokeC=p.id==='obstacle'?'#4a0e0e':'#0c2244';
    const tp=Math.max(4,Math.floor(W/26));
    for(let i=1;i<=tp;i++){
      const px=W/(tp+1)*i;
      g.appendChild(el('rect',{x:px-1.2,y:H,width:2.4,height:10,fill:'#b8b8b8',stroke:'#8a8a8a','stroke-width':0.4}));
    }
    const body=el('rect',{width:W,height:H,rx:7,fill:p.bg,stroke:strokeC,'stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke=strokeC;
    [[10,10],[W-10,10],[10,H-10],[W-10,H-10]].forEach(([cx,cy])=>{
      g.appendChild(el('circle',{cx,cy,r:4.5,fill:'none',stroke:'#c8a93e','stroke-width':2}));
      g.appendChild(el('circle',{cx,cy,r:2.2,fill:'#efeadd'}));
    });
    g.appendChild(el('path',{d:`M26,${H-18} H${W-26} M26,${H-13} H${W-40}`,stroke:'#ffffff',opacity:0.25,'stroke-width':1,fill:'none'}));
  }
  else if(p.shape==='display'){
    const tp=Math.max(4,Math.floor(W/26));
    for(let i=1;i<=tp;i++){
      const px=W/(tp+1)*i;
      g.appendChild(el('rect',{x:px-1.2,y:-10,width:2.4,height:10,fill:'#b8b8b8',stroke:'#8a8a8a','stroke-width':0.4}));
    }
    const body=el('rect',{width:W,height:H,rx:7,fill:p.bg,stroke:'#0a1f10','stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke='#0a1f10';
    [[9,9],[W-9,9],[9,H-9],[W-9,H-9]].forEach(([cx,cy])=>{
      g.appendChild(el('circle',{cx,cy,r:4,fill:'none',stroke:'#c8a93e','stroke-width':1.8}));
      g.appendChild(el('circle',{cx,cy,r:2,fill:'#efeadd'}));
    });
    g.appendChild(el('rect',{x:18,y:20,width:W-36,height:H-44,rx:3,fill:'#0a0d0a',stroke:'#000','stroke-width':1}));
    g.appendChild(el('rect',{x:22,y:24,width:W-44,height:H-52,rx:2,fill:'#0e1610'}));
    g.appendChild(el('rect',{x:22,y:24,width:(W-44)*0.4,height:H-52,fill:'#fff',opacity:0.04}));
  }
  else{
    const ps=p.pins,step=H/(ps+1);
    for(let i=1;i<=ps;i++){
      g.appendChild(el('path',{d:`M-9,${step*i-5} h9 v4 h-9 l-3,3 v-10 Z`,fill:'#b8b8b8',stroke:'#8a8a8a','stroke-width':0.5}));
      g.appendChild(el('path',{d:`M${W},${step*i-5} h9 l3,3 v-10 l-3,3 h-9 Z`,fill:'#b8b8b8',stroke:'#8a8a8a','stroke-width':0.5}));
    }
    const tpCount=Math.max(3,Math.floor(W/40));
    for(let i=1;i<=tpCount;i++){
      const px=W/(tpCount+1)*i;
      g.appendChild(el('rect',{x:px-1.5,y:-9,width:3,height:9,fill:'#b8b8b8',stroke:'#8a8a8a','stroke-width':0.4}));
    }
    const body=el('rect',{width:W,height:H,rx:5,fill:p.bg,stroke:'#3a3a3a','stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke='#3a3a3a';
    g.appendChild(el('rect',{x:3,y:3,width:W-6,height:H*0.32,rx:4,fill:'#fff',opacity:0.05}));
    g.appendChild(el('circle',{cx:W-20,cy:H-14,r:4,fill:'none',stroke:'#fff',opacity:0.08,'stroke-width':1}));
    g.appendChild(el('circle',{cx:13,cy:H-12,r:3,fill:'#000',stroke:'#ffffff22','stroke-width':1}));
    g.appendChild(el('path',{d:`M${W/2-10},0 A10,10 0 0,1 ${W/2+10},0`,fill:'#15151a',stroke:'#000','stroke-width':0.8}));
  }

  // status LED
  const led=el('circle',{cx:W-14,cy:15,r:5.5,fill:'#111',stroke:'#00000055','stroke-width':1});
  const ledInner=el('circle',{cx:W-14,cy:15,r:3.5,fill:p.shape==='display'?'#4ade80':(p.id==='obstacle'?'#ffd49a':p.border),opacity:0.25});
  g.appendChild(led);g.appendChild(ledInner);
  p._led=led;p._ledInner=ledInner;

  // silkscreen text lives in its own group so it can go dark when power is off
  const tg=el('g');
  tg.style.transition='opacity 0.45s';
  const iconY=p.h>110?34:27;
  tg.appendChild(tx(p.icon,{x:p.shape==='display'?26:14,y:iconY,'font-size':p.h>110?20:15,'font-family':'sans-serif'}));
  const nameY=p.h>110?60:46;
  tg.appendChild(tx(p.name,{x:W/2,y:nameY,'text-anchor':'middle','font-size':p.h>110?14:11.5,'font-weight':'bold','font-family':'Courier New,monospace',fill:p.label,'letter-spacing':1.2}));
  tg.appendChild(tx(p.subtitle,{x:W/2,y:nameY+14,'text-anchor':'middle','font-size':p.h>110?10:8.5,'font-family':'Courier New,monospace',fill:subFill}));
  const techY=p.h>110?90:71;
  tg.appendChild(tx(p.tech.slice(0,p.h>110?3:2).join(' · '),{x:W/2,y:techY,'text-anchor':'middle','font-size':7.5,'font-family':'Courier New,monospace',fill:techFill}));
  tg.appendChild(tx(`${p.id.slice(0,4).toUpperCase()}-${200+Math.floor(p.x/10)*3}`,{x:p.shape==='ic'?22:20,y:H-7,'font-size':6,'font-family':'Courier New,monospace',fill:'#ffffff33'}));
  g.appendChild(tg);
  p._tg=tg;

  const hit=el('rect',{width:W,height:H,rx:5,fill:'transparent'});
  hit.addEventListener('click',()=>selectP(p));
  hit.addEventListener('mouseenter', () => { if(powerOn) p._body.setAttribute('stroke-width', '2.5'); });
  hit.addEventListener('mouseleave', () => { if(selected?.id !== p.id) p._body.setAttribute('stroke-width', '1.5'); });
  g.appendChild(hit);
  svg.appendChild(g);
});

const scList=document.getElementById('sc-list');
if(scList){
  PROJECTS.forEach(p=>{
    const b=document.createElement('button');
    b.className='scb';b.textContent=`${p.icon} ${p.name}`;
    b.style.borderColor=p.border+'55';b.style.color=p.border;
    b.addEventListener('click',()=>selectP(p));
    scList.appendChild(b);
  });
}

/* ---------- POWER LOGIC ---------- */
function applyPower(){
  // switch face
  swRing.setAttribute('stroke',powerOn?'#2aa84a':'#4a4a4e');
  swSym.setAttribute('stroke',powerOn?'#4ade80':'#88888c');
  swGlow.style.opacity=powerOn?0.18:0;
  // D1 power indicator: only lit when the switch passes current
  d1Dome.setAttribute('fill',powerOn?'#ff3b2a':'#7a2a22');
  d1Glow.style.opacity=powerOn?0.45:0;
  // downstream wires read dead when unpowered
  wireG.style.opacity=powerOn?1:0.3;
  // chip silkscreen goes dark, status LEDs unlit
  PROJECTS.forEach(p=>{
    p._tg.style.opacity=powerOn?1:0;
    p._ledInner.setAttribute('opacity',powerOn?0.25:0.05);
  });
  // on-board boot instruction
  hintT.style.opacity=powerOn?0:1;
  // header + footer status
  const ss=document.getElementById('sys-status');
  ss.textContent=powerOn?'● SYSTEM: IDLE':'○ SYSTEM: OFF';
  ss.style.color=powerOn?'#1a6b3a':'#a09584';
  const fs=document.getElementById('fstatus');
  fs.textContent=powerOn?'● ALL SYSTEMS OPERATIONAL':'○ POWERED DOWN — PRESS THE POWER SWITCH';
  fs.style.color=powerOn?'#1a6b3a':'#a09584';
  // readout panel
  document.getElementById('pe-sub').textContent=powerOn?'Select a chip to inspect':'No power detected';
  document.getElementById('pe-icon').textContent=powerOn?'🔌':'⏻';
  document.getElementById('pe-txt').innerHTML=powerOn
    ?'TAP A COMPONENT<br><span style="font-size:16px;color:#bdab8e">to power it up</span>'
    :'SYSTEM OFFLINE<br><span style="font-size:20px;color:#bdab8e">press the POWER switch on the top right of the board to boot up</span>';
  if(scList)scList.style.display=powerOn?'flex':'none';
}

function togglePower(){
  if(powerOn){
    if(selected)selectP(selected); // deselect first; readout drops back to empty view
    powerOn=false;
  }else{
    powerOn=true;
  }
  applyPower();
}

function pulseHint(){
  hintT.setAttribute('fill','#ee7a23');
  setTimeout(()=>hintT.setAttribute('fill','#6b5b45'),650);
}

function selectP(p){
  if(!powerOn){pulseHint();return;} // dead board: chips don't respond
  blinkT.forEach(clearInterval);blinkT=[];
  if(selected===p){
    selected=null;
    PROJECTS.forEach(q=>{
      q._body.setAttribute('stroke',q._baseStroke);
      q._body.setAttribute('stroke-width','1.5');
      q._ledInner.setAttribute('opacity',0.25);
    });
    document.getElementById('p-empty-view').style.display='flex';
    document.getElementById('p-detail-view').style.display='none';
    document.getElementById('sys-status').textContent='● SYSTEM: IDLE';
    document.getElementById('sys-status').style.color='#1a6b3a';
    return;
  }
  selected=p;
  PROJECTS.forEach(q=>{
    const s=q.id===p.id;
    q._body.setAttribute('stroke',s?'#ee7a23':q._baseStroke);
    q._body.setAttribute('stroke-width',s?'2.5':'1.5');
    q._ledInner.setAttribute('opacity',s?1:0.25);
  });
  let on=true;
  blinkT.push(setInterval(()=>{on=!on;p._ledInner.setAttribute('opacity',on?1:0.3);},600));
  document.getElementById('sys-status').textContent=`● ACTIVE: ${p.name}`;
  document.getElementById('sys-status').style.color=p.border;
  document.getElementById('p-empty-view').style.display='none';
  const dv=document.getElementById('p-detail-view');
  dv.style.display='flex';
  document.getElementById('panel-hdr-content').innerHTML=`
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
      <div style="display:flex;align-items:center;gap:12px">
        <span style="font-size:36px;line-height:1">${p.icon}</span>
        <div>
          <div class="panel-name">${p.name}</div>
          <div class="panel-sub">${p.subtitle}</div>
        </div>
      </div>
      <button class="cls-btn" onclick="selectP(window.__sp)">✕</button>
    </div>
  `;
  document.getElementById('panel-body-content').innerHTML=`
    <p class="pdesc">${p.desc}</p>
    <div class="pdiv"></div>
    <div>
      <div class="plbl">TECH STACK</div>
      <div class="ptags">${p.tech.map(t=>`<span class="ptag">${t}</span>`).join('')}</div>
    </div>
    <div class="pdiv"></div>
    <div>
      <div class="plbl">KEY FEATURES</div>
      <div class="phls">${p.highlights.map(h=>`<div class="phl"><span class="phl-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span><span>${h}</span></div>`).join('')}</div>
    </div>
    <div class="pdiv"></div>
    ${p.awards.length?`<div><div class="plbl">RECOGNITION</div><div class="pawds">${p.awards.map(a=>`<div class="pawd"><span>🏆</span><span>${a}</span></div>`).join('')}</div></div><div class="pdiv"></div>`:''}
    <div class="plinks">
      <div class="plbl">LINKS</div>
      <div class="plinks-row">
        <a href="${p.github}" target="_blank" class="plink-sm">GitHub <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 10L10 2M10 2H4M10 2v6"/></svg></a>
        <a href="${p.page}" class="plink-sm">Docs <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 10L10 2M10 2H4M10 2v6"/></svg></a>
      </div>
      <a href="${p.page}" class="plink-main">VIEW FULL PROJECT <span>→</span></a>
    </div>
  `;
  window.__sp=p;
  if(window.innerWidth<=880){
    document.getElementById('panel-col').scrollIntoView({behavior:'smooth',block:'nearest'});
  }
}

function zm(d){
  zoom=d===0?1:Math.min(2,Math.max(0.5,zoom+d));
  document.getElementById('bbsvg').style.transform=`scale(${zoom})`;
}
window.zm=zm;
window.selectP=selectP;

// initialize power state instantly (no transition flash), then enable fades
powerOn=POWER_ON_AT_START;
applyPower();
requestAnimationFrame(()=>{
  wireG.style.transition='opacity 0.45s';
  hintT.style.transition='opacity 0.45s';
  d1Glow.style.transition='opacity 0.3s';
  swGlow.style.transition='opacity 0.3s';
});
}

if(document.getElementById('bbsvg')){
  initBreadboard();
} else {
  setTimeout(initBreadboard, 0);
}
</script>