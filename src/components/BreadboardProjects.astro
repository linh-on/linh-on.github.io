drawPC(); // initial render of the loop traces now that the button + LED exist

// boot instruction shown on the board while the system is off
const hintT=tx('⏻  SYSTEM OFF! PLEASE PRESS THE POWER SWITCH TO BOOT',{x:500,y:190,'text-anchor':'middle','font-size':20,'font-weight':'bold','font-family':'Courier New,monospace',fill:'#6b5b45','letter-spacing':2});
hintT.style.paintOrder='stroke';
hintT.setAttribute('stroke','#efeadd');
hintT.setAttribute('stroke-width','6');
hintT.style.opacity=0;
svg.appendChild(hintT);

/* ---------- PROJECT COMPONENTS (draggable) ---------- */
PROJECTS.forEach(p=>{
  const g=el('g',{transform:`translate(${p.x},${p.y})`});
  const W=p.w,H=p.h;
  const subFill=p.shape==='ic'?'#c4c4cc':'#f1ebde';
  const techFill=p.shape==='ic'?'#a7a7b6':'#e6dcc6';

  if(p.shape==='sensor'){
    const strokeC=p.id==='obstacle'?'#4a0e0e':'#0c2244';
    const body=el('rect',{width:W,height:H,rx:7,fill:p.bg,stroke:strokeC,'stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke=strokeC;
    [[10,10],[W-10,10],[10,H-10],[W-10,H-10]].forEach(([cx,cy])=>{
      g.appendChild(el('circle',{cx,cy,r:4.5,fill:'none',stroke:'#c8a93e','stroke-width':2}));
      g.appendChild(el('circle',{cx,cy,r:2.2,fill:'#efeadd'}));
    });
  }
  else if(p.shape==='display'){
    const body=el('rect',{width:W,height:H,rx:7,fill:p.bg,stroke:'#0a1f10','stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke='#0a1f10';
    [[9,9],[W-9,9],[9,H-9],[W-9,H-9]].forEach(([cx,cy])=>{
      g.appendChild(el('circle',{cx,cy,r:4,fill:'none',stroke:'#c8a93e','stroke-width':1.8}));
      g.appendChild(el('circle',{cx,cy,r:2,fill:'#efeadd'}));
    });
    g.appendChild(el('rect',{x:18,y:20,width:W-36,height:H-44,rx:3,fill:'#0a0d0a',stroke:'#000','stroke-width':1}));
    g.appendChild(el('rect',{x:22,y:24,width:W-44,height:H-52,rx:2,fill:'#0e1610'}));
    g.appendChild(el('rect',{x:22,y:24,width:(W-44)*0.4,height:H-52,fill:'#fff',opacity:0.04}));
  }
  else{
    const body=el('rect',{width:W,height:H,rx:5,fill:p.bg,stroke:'#3a3a3a','stroke-width':1.5,filter:'url(#cshadow)'});
    g.appendChild(body);p._body=body;p._baseStroke='#3a3a3a';
    g.appendChild(el('rect',{x:3,y:3,width:W-6,height:H*0.32,rx:4,fill:'#fff',opacity:0.05}));
    g.appendChild(el('circle',{cx:W-20,cy:H-14,r:4,fill:'none',stroke:'#fff',opacity:0.08,'stroke-width':1}));
    g.appendChild(el('circle',{cx:13,cy:H-12,r:3,fill:'#000',stroke:'#ffffff22','stroke-width':1}));
  }

  // status LED — pulled inward on boards with corner screw holes
  const ledX=p.shape==='ic'?W-14:W-28;
  const ledY=p.shape==='ic'?15:17;
  const led=el('circle',{cx:ledX,cy:ledY,r:5.5,fill:'#111',stroke:'#00000055','stroke-width':1});
  const ledInner=el('circle',{cx:ledX,cy:ledY,r:3.5,fill:p.shape==='display'?'#4ade80':(p.id==='obstacle'?'#ffd49a':p.border),opacity:0.25});
  g.appendChild(led);g.appendChild(ledInner);
  p._led=led;p._ledInner=ledInner;

  // silkscreen text lives in its own group so it can go dark when power is off
  const tg=el('g');
  tg.style.transition='opacity 0.45s';
  // Per-component text formatting. Sizes default by chip size, but each
  // project sets its OWN spacing via fmt:{...} in the PROJECTS array so the
  // tech-stack line sits a deliberate distance under the subtitle on every
  // chip (techDY is measured DOWN from the icon baseline, like subDY).
  const big=p.h>125;
  const F=Object.assign(
    big?{iconX:15,iconY:37,nameDY:-4,nameSize:17,subDY:24,subSize:12,techDY:44,techSize:9.5,techCount:3}
       :{iconX:15,iconY:33,nameDY:-3,nameSize:15.5,subDY:21,subSize:11.5,techDY:42,techSize:10,techCount:3},
    p.shape==='display'?{iconX:26}:{},
    p.fmt||{}
  );
  tg.appendChild(tx(p.name,{x:F.iconX,y:F.iconY+F.nameDY,'text-anchor':'start','font-size':F.nameSize,'font-weight':'bold','font-family':'Courier New,monospace',fill:p.label,'letter-spacing':1.2}));
  tg.appendChild(tx(p.subtitle,{x:F.iconX,y:F.iconY+F.subDY,'text-anchor':'start','font-size':F.subSize,'font-family':'Courier New,monospace',fill:subFill}));
  tg.appendChild(tx(p.tech.slice(0,F.techCount).join(' · '),{x:F.iconX,y:F.iconY+F.techDY,'text-anchor':'start','font-size':F.techSize,'font-family':'Courier New,monospace',fill:techFill,'font-weight':500}));
  tg.appendChild(tx(`${p.id.slice(0,4).toUpperCase()}-${200+Math.floor(p.x/10)*3}`,{x:p.shape==='ic'?22:28,y:H-8,'font-size':8,'font-family':'Courier New,monospace',fill:'#ffffff4d'}));
  g.appendChild(tg);
  p._tg=tg;

  // hit area (hover affordance lives here; click/drag handled on the group)
  const hit=el('rect',{width:W,height:H,rx:5,fill:'transparent'});
  hit.addEventListener('mouseenter',()=>{ if(powerOn) p._body.setAttribute('stroke-width','2.5'); });
  hit.addEventListener('mouseleave',()=>{ if(selected?.id!==p.id) p._body.setAttribute('stroke-width','1.5'); });
  g.appendChild(hit);

  // ----- DRAG LOGIC -----
  // A press with <3px of movement counts as a click (select/deselect).
  // Anything more is a drag: chip follows the pointer, wires re-route live.
  // When the DRAG toggle is off, chips are locked: presses are clicks only.
  let dragInfo=null;
  chipGroups.push(g);
  g.addEventListener('pointerdown',ev=>{
    if(ev.pointerType==='mouse'&&ev.button!==0)return;
    ev.stopPropagation(); // chip presses select/drag the chip, never pan the board
    if(!dragEnabled){dragInfo={moved:false};return;} // locked: click-only, native scroll preserved
    ev.preventDefault();
    svg.appendChild(g);svg.appendChild(handleG); // chip to front, wire handles above it
    const [sx,sy]=svgPt(ev);
    dragInfo={ox:sx-p.x,oy:sy-p.y,moved:false};
    try{g.setPointerCapture(ev.pointerId);}catch(e){}
    g.style.cursor='grabbing';
  });
  g.addEventListener('pointermove',ev=>{
    if(!dragInfo||!dragEnabled||dragInfo.ox===undefined)return;
    const [sx,sy]=svgPt(ev);
    const nx=Math.min(BX+BW-10-p.w,Math.max(BX+10,sx-dragInfo.ox));
    const ny=Math.min(BY+BH-12-p.h,Math.max(BY+12,sy-dragInfo.oy));
    if(!dragInfo.moved&&Math.hypot(nx-p.x,ny-p.y)<3)return;
    dragInfo.moved=true;
    p.x=nx;p.y=ny;
    g.setAttribute('transform',`translate(${nx},${ny})`);
    drawWires();
  });
  g.addEventListener('pointerup',()=>{
    if(!dragInfo)return;
    const wasClick=!dragInfo.moved;
    dragInfo=null;
    g.style.cursor=dragEnabled?'grab':'pointer';
    if(wasClick)selectP(p);
  });
  g.addEventListener('pointercancel',()=>{dragInfo=null;g.style.cursor=dragEnabled?'grab':'pointer';});

  svg.appendChild(g);
});
svg.appendChild(handleG); // wire endpoint handles render above all chips
drawWires(); // rebuild now that the handle layer is live

const scList=document.getElementById('sc-list');
if(scList){
  PROJECTS.forEach(p=>{
    const b=document.createElement('button');
    b.className='scb';b.textContent=p.name;
    b.style.borderColor=p.border+'55';b.style.color=p.border;
    b.addEventListener('click',()=>selectP(p));
    scList.appendChild(b);
  });
}

/* ---------- POWER LOGIC ---------- */
function applyPower(){
  // switch face
  swRing.setAttribute('stroke',powerOn?'#2aa84a':'#4a4a4e');
  swSym.setAttribute('stroke',powerOn?'#4ade80':'#88888c');
  swGlow.style.opacity=powerOn?0.18:0;
  // D1 power indicator: only lit when the switch passes current
  d1Dome.setAttribute('fill',powerOn?'#ff3b2a':'#7a2a22');
  d1Glow.style.opacity=powerOn?0.45:0;
  // downstream wires read dead when unpowered
  wireG.style.opacity=powerOn?1:0.3;
  handleG.style.opacity=powerOn?1:0.3;
  drawPC(); // re-colour the power-indicator loop + toggle current flow
  // chip silkscreen goes dark, status LEDs unlit
  PROJECTS.forEach(p=>{
    p._tg.style.opacity=powerOn?1:0;
    p._ledInner.setAttribute('opacity',powerOn?0.25:0.05);
  });
  // on-board boot instruction
  hintT.style.opacity=powerOn?0:1;
  // header + footer status
  const ss=document.getElementById('sys-status');
  ss.textContent=powerOn?'● SYSTEM: IDLE':'○ SYSTEM: OFF';
  ss.style.color=powerOn?'#1a6b3a':'#a09584';
  const fs=document.getElementById('fstatus');
  fs.textContent=powerOn?'● ALL SYSTEMS OPERATIONAL':'○ POWERED DOWN — PRESS THE POWER SWITCH';
  fs.style.color=powerOn?'#1a6b3a':'#a09584';
  // readout panel
  document.getElementById('pe-sub').textContent=powerOn?'Select a chip to inspect':'No power detected';
  document.getElementById('pe-icon').textContent='⏻';
  document.getElementById('pe-txt').innerHTML=powerOn
    ?'TAP A COMPONENT<br><span style="font-size:16px;color:#bdab8e">to power it up</span>'
    :'<span style="font-size:24px;color:#bdab8e; font-weight:bold;">SYSTEM OFFLINE</span><br><span style="font-size:24px;color:#bdab8e">press the POWER switch on the top right of the board to boot up</span>';
  if(scList)scList.style.display=powerOn?'flex':'none';
}

function togglePower(){
  if(powerOn){
    if(selected)selectP(selected); // deselect first; readout drops back to empty view
    powerOn=false;
  }else{
    powerOn=true;
  }
  applyPower();
}

function pulseHint(){
  hintT.setAttribute('fill','#ee7a23');
  setTimeout(()=>hintT.setAttribute('fill','#6b5b45'),650);
}

function selectP(p){
  if(!powerOn){pulseHint();return;} // dead board: chips don't respond
  blinkT.forEach(clearInterval);blinkT=[];
  if(selected===p){
    selected=null;
    PROJECTS.forEach(q=>{
      q._body.setAttribute('stroke',q._baseStroke);
      q._body.setAttribute('stroke-width','1.5');
      q._ledInner.setAttribute('opacity',0.25);
    });
    document.getElementById('p-empty-view').style.display='flex';
    document.getElementById('p-detail-view').style.display='none';
    document.getElementById('sys-status').textContent='● SYSTEM: IDLE';
    document.getElementById('sys-status').style.color='#1a6b3a';
    return;
  }
  selected=p;
  PROJECTS.forEach(q=>{
    const s=q.id===p.id;
    q._body.setAttribute('stroke',s?'#ee7a23':q._baseStroke);
    q._body.setAttribute('stroke-width',s?'2.5':'1.5');
    q._ledInner.setAttribute('opacity',s?1:0.25);
  });
  let on=true;
  blinkT.push(setInterval(()=>{on=!on;p._ledInner.setAttribute('opacity',on?1:0.3);},600));
  document.getElementById('sys-status').textContent=`● ACTIVE: ${p.name}`;
  document.getElementById('sys-status').style.color=p.border;
  document.getElementById('p-empty-view').style.display='none';
  const dv=document.getElementById('p-detail-view');
  dv.style.display='flex';
  document.getElementById('panel-hdr-content').innerHTML=`
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px">
      <div>
        <div class="panel-name">${p.name}</div>
        <div class="panel-sub">${p.subtitle}</div>
      </div>
      <button class="cls-btn" onclick="selectP(window.__sp)">✕</button>
    </div>
  `;
  document.getElementById('panel-body-content').innerHTML=`
    <p class="pdesc">${p.desc}</p>
    <div class="pdiv"></div>
    <div>
      <div class="plbl">TECH STACK</div>
      <div class="ptags">${p.tech.map(t=>`<span class="ptag">${t}</span>`).join('')}</div>
    </div>
    <div class="pdiv"></div>
    <div>
      <div class="plbl">KEY FEATURES</div>
      <div class="phls">${p.highlights.map(h=>`<div class="phl"><span class="phl-check"><svg viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3"/></svg></span><span>${h}</span></div>`).join('')}</div>
    </div>
    <div class="pdiv"></div>
    ${p.awards.length?`<div><div class="plbl">RECOGNITION</div><div class="pawds">${p.awards.map(a=>`<div class="pawd"><span>★</span><span>${a}</span></div>`).join('')}</div></div><div class="pdiv"></div>`:''}
    <div class="plinks">
      <div class="plbl">LINKS</div>
      <div class="plinks-row">
        <a href="${p.github}" target="_blank" class="plink-sm">GitHub <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 10L10 2M10 2H4M10 2v6"/></svg></a>
        <a href="${p.page}" class="plink-sm">Docs <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 10L10 2M10 2H4M10 2v6"/></svg></a>
      </div>
      <a href="${p.page}" class="plink-main">VIEW FULL PROJECT <span>→</span></a>
    </div>
  `;
  window.__sp=p;
  if(window.innerWidth<=880){
    document.getElementById('panel-col').scrollIntoView({behavior:'smooth',block:'nearest'});
  }
}

/* ---------- DRAG TOGGLE ---------- */
function applyDrag(){
  chipGroups.forEach(g=>{
    g.style.cursor=dragEnabled?'grab':'pointer';
    g.style.touchAction=dragEnabled?'none':'auto';
  });
  const b=document.getElementById('dragbtn');
  if(b){
    b.textContent=dragEnabled?'DRAG: ON':'DRAG: OFF';
    b.style.color=dragEnabled?'#1a6b3a':'#6b5b45';
    b.style.borderColor=dragEnabled?'#1a6b3a66':'#cfc7b6';
  }
}
function toggleDrag(){dragEnabled=!dragEnabled;applyDrag();drawWires();}
window.toggleDrag=toggleDrag;

function zm(d){
  if(d===0){fitDefault();return;} // RESET: recenter on the default view
  cam.z=Math.min(ZMAX,Math.max(ZMIN,cam.z+d));
  applyCam();
}
window.zm=zm;
window.selectP=selectP;

/* ---------- BOARD PANNING (drag empty board) + PINCH / CTRL+WHEEL ZOOM ---------- */
// Chips, parts, wire handles and the switch all stopPropagation on
// pointerdown, so anything that reaches the svg itself is "empty board".
const panPtrs=new Map();
let panInfo=null,pinchInfo=null;
svg.addEventListener('pointerdown',ev=>{
  if(ev.pointerType==='mouse'&&ev.button!==0)return;
  panPtrs.set(ev.pointerId,[ev.clientX,ev.clientY]);
  try{svg.setPointerCapture(ev.pointerId);}catch(e){}
  if(panPtrs.size===1){
    panInfo={x:ev.clientX,y:ev.clientY,cx:cam.cx,cy:cam.cy};
    svg.style.cursor='grabbing';
  }else if(panPtrs.size===2){
    panInfo=null;
    const[a,b]=[...panPtrs.values()];
    pinchInfo={d:Math.hypot(a[0]-b[0],a[1]-b[1]),z:cam.z};
  }
});
svg.addEventListener('pointermove',ev=>{
  if(!panPtrs.has(ev.pointerId))return;
  panPtrs.set(ev.pointerId,[ev.clientX,ev.clientY]);
  if(pinchInfo&&panPtrs.size===2){
    const[a,b]=[...panPtrs.values()];
    const d=Math.hypot(a[0]-b[0],a[1]-b[1]);
    if(pinchInfo.d>0){cam.z=pinchInfo.z*d/pinchInfo.d;applyCam();}
    return;
  }
  if(!panInfo)return;
  const r=svg.getBoundingClientRect();
  const s=Math.max(r.width/VB.w,r.height/VB.h); // rendered px per board unit
  cam.cx=panInfo.cx-(ev.clientX-panInfo.x)/s;
  cam.cy=panInfo.cy-(ev.clientY-panInfo.y)/s;
  applyCam();
});
function endPan(ev){
  panPtrs.delete(ev.pointerId);
  pinchInfo=null;
  if(panPtrs.size===1){ // dropped from pinch to one finger: restart pan cleanly
    const[[ ,pt]]=[...panPtrs.entries()];
    panInfo={x:pt[0],y:pt[1],cx:cam.cx,cy:cam.cy};
  }else{
    panInfo=null;
    svg.style.cursor='grab';
  }
}
svg.addEventListener('pointerup',endPan);
svg.addEventListener('pointercancel',endPan);

// Ctrl/Cmd + scroll (and trackpad pinch) zooms toward the cursor
svg.addEventListener('wheel',ev=>{
  if(!ev.ctrlKey&&!ev.metaKey)return;
  ev.preventDefault();
  const[wx,wy]=svgPt(ev);
  const oldZ=cam.z;
  cam.z=Math.min(ZMAX,Math.max(ZMIN,cam.z*(ev.deltaY<0?1.12:1/1.12)));
  // keep the board point under the cursor fixed while zooming
  cam.cx=wx-(wx-cam.cx)*(oldZ/cam.z);
  cam.cy=wy-(wy-cam.cy)*(oldZ/cam.z);
  applyCam();
},{passive:false});

window.addEventListener('resize',applyCam);

// initialize power + drag state instantly (no transition flash), then enable fades
powerOn=POWER_ON_AT_START;
applyPower();
applyDrag();
fitDefault();
requestAnimationFrame(fitDefault); // refit once layout fully settles
requestAnimationFrame(()=>{
  wireG.style.transition='opacity 0.45s';
  hintT.style.transition='opacity 0.45s';
  d1Glow.style.transition='opacity 0.3s';
  swGlow.style.opacity=swGlow.style.opacity; // touch to flush
  swGlow.style.transition='opacity 0.3s';
});
}

if(document.getElementById('bbsvg')){
  initBreadboard();
} else {
  setTimeout(initBreadboard, 0);
}
</script>