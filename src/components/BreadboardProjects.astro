const swSym=el('g',{stroke:'#88888c','stroke-width':2.8,fill:'none','stroke-linecap':'round'});
swSym.appendChild(el('path',{d:'M-6,-5 A8.4,8.4 0 1 0 6,-5'}));
swSym.appendChild(el('line',{x1:0,y1:-10.5,x2:0,y2:-1.2}));
swInner.appendChild(swSym);
swG.appendChild(tx('POWER',{x:0,y:SW_R+20,'font-size':11,'font-family':'monospace',fill:'#8a8273','text-anchor':'middle','font-weight':'bold','letter-spacing':1.5}));
swG.addEventListener('mousedown',()=>swCap.setAttribute('r','13'));
swG.addEventListener('mouseup',()=>swCap.setAttribute('r','14'));
swG.addEventListener('mouseleave',()=>swCap.setAttribute('r','14'));
// a press that dragged the button must not also toggle power
