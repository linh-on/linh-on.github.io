// specular highlight
d1Inner.appendChild(el('ellipse',{cx:-3.2,cy:-3.2,rx:3.4,ry:2.4,fill:'#ffffff',opacity:0.6}));
d1Inner.appendChild(tx('D1',{x:0,y:30,'font-size':10,'font-family':'monospace',fill:'#8a8273','text-anchor':'middle','font-weight':'bold'}));
svg.appendChild(d1G);
makeDraggable(d1G,d1Pos,BX+28,BX+BW-28,BY+28,BY+BH-38,drawPC);

// POWER push switch — large round latching power button, top-right (draggable;
// its rail trace re-routes live, and the label travels with it)
const swG=el('g',{transform:`translate(${BC.x},${BC.y})`});
const swInner=el('g',{transform:`scale(${SW_SCALE})`}); // enlarged button; terminals scale via SW_R
swG.appendChild(swInner);
const swGlow=el('circle',{r:34,fill:'#2aa84a'});
swGlow.style.opacity=0;
swInner.appendChild(swGlow);
