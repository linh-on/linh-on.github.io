<script is:inline>
// @ts-nocheck
function initBreadboard() {
const NS='http://www.w3.org/2000/svg';

/* ---------- BOARD EXTENT & CAMERA ----------
 The breadboard is twice the default view in each direction, so zooming
 out reveals MORE board instead of blank space, and the board can be
 panned around by dragging any empty area. At maximum zoom-out the
 visible area exactly fits inside the board (never past its edges). */
const BASE_W=1000,BASE_H=580;            // camera size at zoom = 1 (the default view)
const BX=-500,BY=-290,BW=2000,BH=1160;   // full board extent (default view sits centered)
const CHANNELS=[-192,-8,176,360,544,728];// horizontal DIP-channel dividers across the board
const ZMIN=Math.max(BASE_W/BW,BASE_H/BH);// fully zoomed out = board still fills the view
const ZMAX=2;

// Set to true to have the board already powered on when the page loads.
const POWER_ON_AT_START=false;
// Set to false to start with components locked in place (drag off).
const DRAG_ON_AT_START=true;

/*
 CIRCUIT TOPOLOGY:
   POWER-ON INDICATOR LOOP (top-right, fully traced):
     +RAIL ──> POWER push switch ──> D1 LED (anode→cathode) ──> −RAIL
     A real series loop: current leaves the + rail, passes through the
     latching POWER button, lights the D1 indicator LED, and returns to
     the − rail. When the switch is OFF the loop is broken: the traces go
     grey, no current animates, and the LED stays dark.
   +RAIL ──> PAWSE (MCU / brain)
   DEEP DIABETES (analog sensor) ──SIGNAL──> PAWSE
   OBSTACLE BOT (ToF sensor board) ──I2C DATA──> PAWSE
   PAWSE ──DATA+CLK──> ABLEWARE (display module)
   PAWSE ──PWM──> ARCTOS (motor driver, bottom section)
   ABLEWARE ──> DRAMA TRACKER (memory IC) ──> SPIDER (coprocessor) ──> NEW (expansion slot)
   GND rail ──> ARCTOS
 Components are draggable: wires are anchored to chips and re-route live.
 When the switch is OFF, nothing downstream has power: wires read dead,
 silkscreen text is dark, status LEDs are unlit, and chips don't respond to clicks.
*/

const PROJECTS=[
  {id:'pawse',name:'PAWSE',subtitle:'Smart Notification Classifier',bg:'#1b1b1f',border:'#16a34a',label:'#4ade80',x:30,y:22,w:270,h:140,pins:5,shape:'ic',tech:['Python','MobileBERT','ESP32','React Native','BLE','Supabase'],desc:'A phone lockbox that physically locks your phone during focus sessions, with AI-powered notification filtering.',highlights:['95%+ MobileBERT classifier accuracy','BLE hardware-software bridge','FreeRTOS firmware on ESP32','School mode with roster polling'],awards:['Semifinalist — UCI Stella Zhang New Venture Competition','Semifinalist — Beall & Butterworth 2026'],github:'https://github.com/linh-on/pawse',page:'/projects/pawse',fmt:{subDY:27,subSize:13,techDY:52,techSize:11}},
  {id:'ableware',name:'ABLEWARE',subtitle:'Assistive Lift System',bg:'#11301c',border:'#1d4ed8',label:'#6ee7a0',x:420,y:24,w:260,h:135,pins:5,shape:'display',tech:['Python','Raspberry Pi','Arduino','WebSocket','FastAPI','TypeScript'],desc:'Voice-controlled assistive lift. A Pi listens for wake words and sends commands over WebSocket to a hub coordinating hardware and simulation.',highlights:['Wake word + Vosk voice pipeline','WebSocket hub architecture','PyBullet 3D simulation','React/TypeScript dashboard'],awards:['2nd Place — 2026 UCI MCS ICS Expo'],github:'https://github.com/EliyaKhajeiee/ableware-pi-final',page:'/projects/ableware',fmt:{subDY:27,subSize:12.5,techDY:50,techSize:9.5}},
  {id:'drama',name:'DRAMA TRACKER',subtitle:'Movie Web App',bg:'#231c0e',border:'#b45309',label:'#fcd34d',x:740,y:225,w:230,h:115,pins:3,shape:'ic',tech:['React.js','Node.js','PostgreSQL','Python','Flask','TMDB API'],desc:'Full-stack movie tracking app with a content-based filtering recommendation engine using TF-IDF cosine similarity.',highlights:['TF-IDF content filtering','TMDB API integration','Flask recommendation service','Vercel + Render deployed'],awards:[],github:'https://github.com/linh-on/drama-tracker',page:'/projects/drama-tracker',fmt:{subDY:21,techDY:42}},
  {id:'diabetes',name:'DEEP DIABETES',subtitle:'Risk Prediction Model',bg:'#16335e',border:'#0e7490',label:'#7dd3fc',x:30,y:225,w:230,h:115,pins:3,shape:'sensor',tech:['Python','PyTorch','Scikit-learn','Pandas','NumPy'],desc:'Deep MLP for diabetes risk prediction on CDC BRFSS 2015 data, outperforming baseline classifiers.',highlights:['Weighted BCE for imbalance','AdamW + CosineAnnealing LR','Early stopping on ROC-AUC','Feature ablation analysis'],awards:[],github:'https://github.com/juliethecao/deep-diabetes-risk',page:'/projects/deep-diabetes-risk',fmt:{subDY:21,techDY:42}},
  {id:'obstacle',name:'OBSTACLE BOT',subtitle:'Autonomous Avoidance Vehicle',bg:'#8f2424',border:'#b91c1c',label:'#ffe3c2',x:385,y:222,w:240,h:115,pins:3,shape:'sensor',tech:['Arduino','C++','VL53L1X ToF','TCA9548A','DRV8835'],desc:'Arduino-based autonomous vehicle that navigates around obstacles using time-of-flight distance sensors and differential drive motors.',highlights:['VL53L1X ToF sensor array','TCA9548A I2C multiplexer','DRV8835 motor driver control','Real-time avoidance logic'],awards:[],github:'https://github.com/linh-on',page:'/projects/obstacle-avoidance-vehicle',fmt:{subDY:21,subSize:11,techDY:42}},
  {id:'arctos',name:'ARCTOS 6-DOF',subtitle:'Robotic Arm',bg:'#1e1a2e',border:'#7c3aed',label:'#c4b5fd',x:30,y:415,w:230,h:115,pins:3,shape:'ic',tech:['Arduino','C++','Python','Arctos Studio','3D Printing'],desc:'6-DOF robotic arm using Arduino MEGA coordinating stepper motors across all joints for competition tasks.',highlights:['6-joint stepper motor control','Custom CAD end-effector','Waypoint programming','Cup stacking & weight lift'],awards:[],github:'https://github.com/linh-on',page:'/projects/arctos-robotic-arm',fmt:{subDY:21,techDY:42}},
  {id:'spider',name:'SPIDER DROID',subtitle:'Autonomous Robot',bg:'#241313',border:'#b91c1c',label:'#fca5a5',x:400,y:420,w:200,h:115,pins:3,shape:'ic',tech:['Python','PyTorch','PPO','Jetson Nano','LiDAR'],desc:'3D-printed spider robot trained with PPO RL to walk autonomously across varied terrain, deployed on Jetson Nano.',highlights:['PPO reinforcement learning','LiDAR obstacle detection','Jetson Nano deployment','No external compute'],awards:[],github:'https://github.com/linh-on',page:'/projects/ai-spider-droid',fmt:{subDY:21,techDY:42,techSize:9.5}},
  {id:'new',name:'NEW',subtitle:'To be put in',bg:'#2a2a2e',border:'#9ca3af',label:'#e5e7eb',x:740,y:420,w:230,h:115,pins:3,shape:'ic',tech:['TBD'],desc:'Reserved slot for an upcoming project.',highlights:[],awards:[],github:'https://github.com/linh-on',page:'#',fmt:{subDY:21,techDY:42}},
];

/*
 Wires are anchored, not hardcoded. Each endpoint is one of:
   {x,y}            fixed board coordinate
   {p:'id',dx,dy}   attached to a project chip, offset from its top-left corner
   {rail:'top'|'bottom'}  power-rail tap that follows the chip horizontally
 Routes are recomputed every drag frame by drawWires().
*/
const WIRES=[
  {a:{rail:'top'},    b:{p:'pawse',dx:40,dy:0},      color:'#d8281c'}, // VCC: top rail -> MCU
  {a:{rail:'bottom'}, b:{p:'arctos',dx:100,dy:115},  color:'#2e2e32'}, // GND: bottom rail -> motor driver
  {a:{p:'diabetes',dx:115,dy:0},  b:{p:'pawse',dx:100,dy:140},  color:'#2563eb'}, // SIGNAL: diabetes sensor -> MCU
  {a:{p:'obstacle',dx:120,dy:0},  b:{p:'pawse',dx:170,dy:140},  color:'#e8a013', via:188}, // I2C DATA via channel 1
  {a:{p:'pawse',dx:235,dy:140},   b:{p:'arctos',dx:40,dy:0},    color:'#f47b20', via:366}, // PWM via channel 2
  {a:{p:'pawse',dx:270,dy:80},    b:{p:'ableware',dx:0,dy:85},  color:'#22a04a', lane:0.42}, // DATA: MCU -> display
  {a:{p:'pawse',dx:270,dy:94},    b:{p:'ableware',dx:0,dy:99},  color:'#2563eb', lane:0.58}, // CLK:  MCU -> display
  {a:{p:'ableware',dx:215,dy:135},b:{p:'drama',dx:120,dy:0},    color:'#0ea5b7'}, // BUS: display -> memory IC below
  {a:{p:'drama',dx:215,dy:115},   b:{p:'spider',dx:100,dy:0},   color:'#c89b2a', via:370}, // ADDR via channel 2
  {a:{p:'spider',dx:200,dy:57},   b:{p:'new',dx:0,dy:57},       color:'#7c3aed'}, // EXP: coprocessor -> expansion slot
];

let selected=null,blinkT=[],powerOn=true,dragEnabled=DRAG_ON_AT_START;
const chipGroups=[];
const svg=document.getElementById('bbsvg');
if(!svg) return;
const pMap={};PROJECTS.forEach(p=>pMap[p.id]=p);

function el(tag,a={}){const e=document.createElementNS(NS,tag);for(const[k,v]of Object.entries(a))e.setAttribute(k,v);return e;}
function tx(s,a={}){const e=el('text',a);e.textContent=s;return e;}

/* ---------- BOARD SURFACE ---------- */
const defs=el('defs');
const pat=el('pattern',{id:'h',width:14.5,height:17,patternUnits:'userSpaceOnUse'});
pat.appendChild(el('circle',{cx:7,cy:8,r:2.4,fill:'#cdc6b4'}));
pat.appendChild(el('rect',{x:5.6,y:6.6,width:2.8,height:2.8,rx:0.6,fill:'#5a564c'}));
defs.appendChild(pat);
const f=el('filter',{id:'cshadow',x:'-20%',y:'-20%',width:'140%',height:'140%'});
f.appendChild(el('feDropShadow',{dx:'2',dy:'3',stdDeviation:'2.5','flood-color':'#3a2e1a','flood-opacity':'0.3'}));
defs.appendChild(f);
svg.appendChild(defs);

svg.appendChild(el('rect',{x:BX,y:BY,width:BW,height:BH,fill:'#efeadd'}));
svg.appendChild(el('rect',{x:BX,y:BY,width:BW,height:BH,fill:'url(#h)'}));
// DIP-channel ravines split the expanded board into terminal sections
CHANNELS.forEach(cy=>{
  svg.appendChild(el('rect',{x:BX,y:cy,width:BW,height:16,fill:'#e2dcca'}));
  svg.appendChild(el('rect',{x:BX,y:cy+2,width:BW,height:6,fill:'#d8d1bb'}));
  svg.appendChild(el('line',{x1:BX,y1:cy,x2:BX+BW,y2:cy,stroke:'#c6bfa9','stroke-width':1}));
  svg.appendChild(el('line',{x1:BX,y1:cy+16,x2:BX+BW,y2:cy+16,stroke:'#fbf8ef','stroke-width':1}));
});

// Power bus rails: red (+) line on top, blue (−) line below, holes in groups of 5,
// with +/− markings at both ends — same layout as a real half-size breadboard.
['rt','rb'].forEach(id=>{
  const r=document.getElementById(id);if(!r)return;
  r.innerHTML='';
  [['+','rlbl-red','top:2px;left:14px'],['+','rlbl-red','top:2px;right:14px'],
   ['−','rlbl-blue','bottom:2px;left:14px'],['−','rlbl-blue','bottom:2px;right:14px']].forEach(([t,cls,pos])=>{
    const s=document.createElement('span');s.className='rlbl '+cls;s.style.cssText=pos;s.textContent=t;r.appendChild(s);
  });
  const lr=document.createElement('div');lr.className='rline rline-red';r.appendChild(lr);
  const holes=document.createElement('div');holes.className='rholes';
  for(let gI=0;gI<10;gI++){
    const grp=document.createElement('div');grp.className='rgrp';
    for(let j=0;j<5;j++){const h=document.createElement('div');h.className='rhole';grp.appendChild(h);}
    holes.appendChild(grp);
  }
  r.appendChild(holes);
  const lb=document.createElement('div');lb.className='rline rline-blue';r.appendChild(lb);
});

// (row letters and edge column numbers removed — the board now extends
//  past the default view, so edge labels would float mid-board)

/* ---------- DYNAMIC JUMPER WIRES ---------- */
const wireG=el('g');
svg.appendChild(wireG);
/* ---------- POWER-CIRCUIT TRACE LAYER ----------
 The POWER switch -> D1 LED indicator loop is drawn as live traces in its
 own layer, sitting just above the jumper wires but below the chips and the
 switch/LED bodies. Both endpoints tap the top power rail, so the loop reads
 as a real series circuit: +RAIL -> button -> LED anode/cathode -> -RAIL. */
const pcG=el('g');
svg.appendChild(pcG);
const BC={x:905,y:64};   // POWER button centre — top-right corner (draggable; traces re-route live)
const SW_SCALE=1.35;         // POWER button enlargement factor
const SW_R=26*SW_SCALE;      // scaled outer radius — where the traces terminate
const D1_SCALE=1.25;         // D1 LED enlargement factor
const D1_LEAD=18*D1_SCALE;   // scaled LED lead length
let d1Pos=null;          // D1 LED centre (assigned + made draggable below)
const handleG=el('g'); // endpoint grab handles — appended above the chips later

function routeD(pts,r=6){
  let d=`M${pts[0][0]},${pts[0][1]}`;
  for(let i=1;i<pts.length-1;i++){
    const [px,py]=pts[i-1],[cx,cy]=pts[i],[nx,ny]=pts[i+1];
    const inL=Math.hypot(cx-px,cy-py),outL=Math.hypot(nx-cx,ny-cy);
    if(inL<0.01||outL<0.01)continue;
    const rr=Math.min(r,inL/2,outL/2);
    const ax=cx-(cx-px)/inL*rr, ay=cy-(cy-py)/inL*rr;
    const bx=cx+(nx-cx)/outL*rr, by=cy+(ny-cy)/outL*rr;
    d+=` L${ax},${ay} Q${cx},${cy} ${bx},${by}`;
  }
  const last=pts[pts.length-1];
  d+=` L${last[0]},${last[1]}`;
  return d;
}

function endPt(e,other){
  if(e.rail){
    const o=other?endPt(other):null;
    const x=o?o[0]:500;
    return[x,e.rail==='top'?BY+2:BY+BH-2];
  }
  if(e.p){const q=pMap[e.p];return[q.x+e.dx,q.y+e.dy];}
  return[e.x,e.y];
}

// Manhattan route between two anchor points.
//  via:  route through a fixed horizontal lane (the center channel) — keeps
//        cross-board wires parallel instead of crossing at random midpoints
//  lane: fraction along the dominant axis where the elbow sits (default 0.5),
//        so parallel wires like DATA/CLK don't share the same elbow
function wirePts(w){
  const A=endPt(w.a,w.b),B=endPt(w.b,w.a);
  const pts=[A];
  // a via lane is only honored while it actually lies between the two ends —
  // drag an end past the lane and the wire collapses to a direct route
  const useVia=typeof w.via==='number'
    &&w.via>Math.min(A[1],B[1])+6
    &&w.via<Math.max(A[1],B[1])-6;
  if(useVia){
    pts.push([A[0],w.via],[B[0],w.via]);
  }else if(Math.abs(A[0]-B[0])>2&&Math.abs(A[1]-B[1])>2){
    const t=(typeof w.lane==='number')?w.lane:0.5;
    if(Math.abs(B[0]-A[0])>Math.abs(B[1]-A[1])){
      const mx=A[0]+(B[0]-A[0])*t;
      pts.push([mx,A[1]],[mx,B[1]]);
    }else{
      const my=A[1]+(B[1]-A[1])*t;
      pts.push([A[0],my],[B[0],my]);
    }
  }
  pts.push(B);
  // drop consecutive duplicates so collinear vias don't create zero-length kinks
  const out=[];
  pts.forEach(pt=>{
    const l=out[out.length-1];
    if(!l||Math.abs(l[0]-pt[0])>0.5||Math.abs(l[1]-pt[1])>0.5)out.push(pt);
  });
  return out;
}

function drawWires(){
  while(wireG.firstChild)wireG.removeChild(wireG.firstChild);
  while(handleG.firstChild)handleG.removeChild(handleG.firstChild);
  WIRES.forEach(w=>{
    const pts=wirePts(w);
    const d=routeD(pts);
    wireG.appendChild(el('path',{d,stroke:'#3a2e1a',opacity:0.15,'stroke-width':4.4,fill:'none','stroke-linecap':'round','stroke-linejoin':'round',transform:'translate(1.4,2.2)'}));
    wireG.appendChild(el('path',{d,stroke:w.color,'stroke-width':3.4,fill:'none','stroke-linecap':'round','stroke-linejoin':'round'}));
    wireG.appendChild(el('path',{d,stroke:'#ffffff',opacity:0.38,'stroke-width':1,fill:'none','stroke-linecap':'round',transform:'translate(-0.5,-0.8)'}));
    // endpoint ferrules + invisible grab handles (drag to unplug/re-route a wire end)
    [['a',pts[0]],['b',pts[pts.length-1]]].forEach(([end,[px,py]])=>{
      handleG.appendChild(el('circle',{cx:px,cy:py,r:2.3,fill:'#9c9c9c',stroke:'#6e6e6e','stroke-width':0.6}));
      const grab=el('circle',{cx:px,cy:py,r:7,fill:'transparent'});
      grab.style.cursor=dragEnabled?'grab':'default';
      grab.style.touchAction='none';
      grab.addEventListener('pointerdown',ev=>{
        if(!dragEnabled)return;
        if(ev.pointerType==='mouse'&&ev.button!==0)return;
        ev.preventDefault();ev.stopPropagation();
        try{svg.setPointerCapture(ev.pointerId);}catch(e){}
        wireDrag={w,end};
      });
      handleG.appendChild(grab);
    });
  });
  drawPC();
}

/* ---------- POWER-INDICATOR LOOP (live traces) ----------
 Three series segments forming the real loop, re-routed every frame so the
 D1 LED can be dragged anywhere and the traces follow:
   1) + rail  -> POWER button left terminal   (red)
   2) button right terminal -> D1 anode        (red)
   3) D1 cathode -> − rail                      (blue)
 Powered: traces take their rail colours and a white "current" dash flows
 along them. Unpowered: traces go dead grey, no flow. */
const RAILY=BY+2; // traces run to the true top edge of the board (the + / − rails), never cut mid-board
function drawPC(){
  if(!d1Pos)return;                 // LED not built yet (first drawWires call)
  while(pcG.firstChild)pcG.removeChild(pcG.firstChild);
  const R=SW_R,LEAD=D1_LEAD;
  const bx=BC.x,by=BC.y,lx=d1Pos.x,ly=d1Pos.y;
  const segs=[
    {pts:[[bx-R,RAILY],[bx-R,by]],      col:'#d8281c'}, // + rail -> button (left terminal)
    {pts:[[bx+R,by],[lx-LEAD,ly]],      col:'#d8281c'}, // button -> LED anode
    {pts:[[lx+LEAD,ly],[lx+LEAD,RAILY]],col:'#2a5ac4'}, // LED cathode -> − rail
  ];
  segs.forEach(s=>{
    const d=routeD(s.pts);
    pcG.appendChild(el('path',{d,stroke:'#3a2e1a',opacity:0.15,'stroke-width':5.2,fill:'none','stroke-linecap':'round','stroke-linejoin':'round',transform:'translate(1.4,2.2)'}));
    pcG.appendChild(el('path',{d,stroke:powerOn?s.col:'#9a958c','stroke-width':4.2,fill:'none','stroke-linecap':'round','stroke-linejoin':'round'}));
    pcG.appendChild(el('path',{d,stroke:'#ffffff',opacity:0.32,'stroke-width':1.1,fill:'none','stroke-linecap':'round',transform:'translate(-0.5,-0.8)'}));
    if(powerOn){
      const flow=el('path',{d,stroke:'#ffffff',opacity:0.9,'stroke-width':2,fill:'none','stroke-linecap':'round'});
      flow.setAttribute('class','bb-flow');
      pcG.appendChild(flow);
    }
  });
  // solder pads at every terminal + where each trace taps the rails
  [[bx-R,by],[bx+R,by],[lx-LEAD,ly],[lx+LEAD,ly],[bx-R,RAILY],[lx+LEAD,RAILY]].forEach(([px,py])=>{
    pcG.appendChild(el('circle',{cx:px,cy:py,r:2.8,fill:'#bdbdbd',stroke:'#7a7a7a','stroke-width':0.7}));
  });
}

// Wire-end dragging: handles are rebuilt every frame, so the move/up
// listeners live on the svg itself, which persists across redraws.
// Dragging a chip-attached end unplugs it into a free {x,y} endpoint.
let wireDrag=null;
svg.addEventListener('pointermove',ev=>{
  if(!wireDrag)return;
  const[sx,sy]=svgPt(ev);
  wireDrag.w[wireDrag.end]={x:Math.min(BX+BW-4,Math.max(BX+4,sx)),y:Math.min(BY+BH-2,Math.max(BY+2,sy))};
  drawWires();
});
// On release, re-plug the end if it was dropped on something:
//  - near the board's top/bottom edge -> becomes a rail tap again
//  - on or near a chip (8px margin) -> snaps to the chip's nearest edge
//    and follows that chip from then on
svg.addEventListener('pointerup',()=>{
  if(!wireDrag)return;
  const w=wireDrag.w,end=wireDrag.end,e=w[end];
  if(e&&typeof e.x==='number'){
    if(e.y<=BY+12){w[end]={rail:'top'};}
    else if(e.y>=BY+BH-12){w[end]={rail:'bottom'};}
    else{
      for(const p of PROJECTS){
        if(e.x>=p.x-8&&e.x<=p.x+p.w+8&&e.y>=p.y-8&&e.y<=p.y+p.h+8){
          let dx=Math.min(p.w,Math.max(0,e.x-p.x));
          let dy=Math.min(p.h,Math.max(0,e.y-p.y));
          const dL=dx,dR=p.w-dx,dT=dy,dB=p.h-dy;
          const m=Math.min(dL,dR,dT,dB);
          if(m===dL)dx=0;else if(m===dR)dx=p.w;else if(m===dT)dy=0;else dy=p.h;
          w[end]={p:p.id,dx,dy};
          break;
        }
      }
    }
    drawWires();
  }
  wireDrag=null;
});
svg.addEventListener('pointercancel',()=>{wireDrag=null;});

// Generic drag for small board parts (the D1 LED). Honors the DRAG toggle.
// onMove (optional) fires every drag frame, e.g. to re-route attached traces.
function makeDraggable(group,pos,minX,maxX,minY,maxY,onMove){
  let di=null;
  chipGroups.push(group); // picks up cursor + touch-action from the DRAG toggle
  group.addEventListener('pointerdown',ev=>{
    if(ev.pointerType==='mouse'&&ev.button!==0)return;
    ev.stopPropagation(); // don't start a board pan from a part
    if(!dragEnabled)return;
    ev.preventDefault();
    const[sx,sy]=svgPt(ev);
    di={ox:sx-pos.x,oy:sy-pos.y,moved:false};
    try{group.setPointerCapture(ev.pointerId);}catch(e){}
    group.style.cursor='grabbing';
  });
  group.addEventListener('pointermove',ev=>{
    if(!di)return;
    const[sx,sy]=svgPt(ev);
    const nx=Math.min(maxX,Math.max(minX,sx-di.ox));
    const ny=Math.min(maxY,Math.max(minY,sy-di.oy));
    // <3px of travel still counts as a click (lets clickable parts like the
    // POWER switch be draggable without every press toggling them)
    if(!di.moved&&Math.hypot(nx-pos.x,ny-pos.y)<3)return;
    di.moved=true;
    pos.x=nx;pos.y=ny;
    group.setAttribute('transform',`translate(${pos.x},${pos.y})`);
    if(onMove)onMove();
  });
  const endPart=()=>{group._dragMoved=!!(di&&di.moved);di=null;group.style.cursor=dragEnabled?'grab':'pointer';};
  group.addEventListener('pointerup',endPart);
  group.addEventListener('pointercancel',endPart);
}

// Convert a pointer event to SVG user coordinates. Derives scale from the
// rendered bounding box + live camera viewBox ('slice' mode: scale is the
// larger ratio, so the board always covers the container with no gaps).
const VB={x:0,y:0,w:BASE_W,h:BASE_H};
function svgPt(ev){
  const r=svg.getBoundingClientRect();
  const s=Math.max(r.width/VB.w,r.height/VB.h);
  const ox=(r.width-VB.w*s)/2,oy=(r.height-VB.h*s)/2;
  return[VB.x+(ev.clientX-r.left-ox)/s,VB.y+(ev.clientY-r.top-oy)/s];
}

/* ---------- CAMERA: zoom + pan over the expanded board ---------- */
const cam={cx:BX+BW/2,cy:BY+BH/2,z:1};
function applyCam(){
  cam.z=Math.min(ZMAX,Math.max(ZMIN,cam.z));
  const w=BASE_W/cam.z,h=BASE_H/cam.z;
  // keep the camera inside the board so blank space never shows
  cam.cx=Math.min(BX+BW-w/2,Math.max(BX+w/2,cam.cx));
  cam.cy=Math.min(BY+BH-h/2,Math.max(BY+h/2,cam.cy));
  VB.x=cam.cx-w/2;VB.y=cam.cy-h/2;VB.w=w;VB.h=h;
  svg.setAttribute('viewBox',`${VB.x} ${VB.y} ${w} ${h}`);
}
// On narrow/tall containers 'slice' crops the sides, which could hide the
// POWER switch. Fit-zoom guarantees the whole default region stays visible.
function fitDefault(){
  const r=svg.getBoundingClientRect();
  if(!r.width||!r.height)return;
  const a=r.width/BASE_W,b=r.height/BASE_H;
  cam.z=Math.min(a,b)/Math.max(a,b); // ≤1; shrinks until the full default region fits
  cam.cx=BX+BW/2;cam.cy=BY+BH/2;
  applyCam();
}

drawWires();

/* ---------- POWER-ON INDICATOR CIRCUIT: POWER switch -> D1 LED ----------
 The current-limiting resistor has been removed for clarity. The loop now
 reads cleanly: + rail -> POWER button -> D1 LED -> − rail (see drawPC). */

// D1 power LED — large 5mm-style indicator, lit only when switched on (draggable)
d1Pos={x:975,y:64};
const d1G=el('g',{transform:`translate(${d1Pos.x},${d1Pos.y})`});
const d1Inner=el('g',{transform:`scale(${D1_SCALE})`}); // enlarged LED; terminals scale via D1_LEAD
d1G.appendChild(d1Inner);
const d1Glow=el('circle',{cx:0,cy:0,r:22,fill:'#ff5b3a'});
d1Glow.style.opacity=0;
d1Inner.appendChild(d1Glow);
// short leads from the body out to the trace terminals
d1Inner.appendChild(el('line',{x1:-18,y1:0,x2:-10,y2:0,stroke:'#b4b4b4','stroke-width':2.6,'stroke-linecap':'round'}));
d1Inner.appendChild(el('line',{x1:10,y1:0,x2:18,y2:0,stroke:'#b4b4b4','stroke-width':2.6,'stroke-linecap':'round'}));
