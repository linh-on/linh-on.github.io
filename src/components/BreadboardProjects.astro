<div class="bb-outer">
<style is:global>
.bb-outer, .bb-outer *{box-sizing:border-box;margin:0;padding:0;}
.bb-outer{width:100%;height:calc(100vh - 130px);min-height:540px;display:block;}
.wrap{font-family:'Courier New',monospace;background:#fdfaf3;padding:12px 16px 12px;border-radius:0;height:100%;display:flex;flex-direction:column;}
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;flex-wrap:wrap;gap:8px;}
.ttl{font-size:24px;color:#1a6b3a;letter-spacing:4px;font-weight:bold;}
.leg{display:flex;gap:22px;font-size:24px;font-weight:bold;color:#6b5b45;flex-wrap:wrap;margin-left:auto;align-items:center;}
.main{display:flex;gap:16px;flex:1;min-height:0;}

/* ---------- BOARD ---------- */
.board-col{flex:1 1 0;min-width:0;display:flex;flex-direction:column;background:#e9e4d8;border:1px solid #cfc7b6;border-radius:14px;overflow:hidden;box-shadow:0 4px 14px rgba(90,70,40,0.08), inset 0 1px 0 rgba(255,255,255,0.6);}
.rail{height:36px;display:flex;flex-direction:column;justify-content:space-between;padding:5px 36px;flex-shrink:0;position:relative;}
.rail-t{background:linear-gradient(#f0ece1,#e9e4d8);border-bottom:1px solid #d8d2c2;}
.rail-b{background:linear-gradient(#e9e4d8,#f0ece1);border-top:1px solid #d8d2c2;}
.rline{height:2.5px;border-radius:2px;}
.rline-red{background:#d8281c;}
.rline-blue{background:#2a5ac4;}
.rholes{display:flex;justify-content:space-between;align-items:center;flex:1;padding:3px 2px;}
.rgrp{display:flex;gap:8px;}
.rhole{width:5px;height:5px;background:#3a362c;border-radius:1px;box-shadow:0 0 0 2px #cdc6b4, inset 0 1px 1px rgba(0,0,0,0.6);}
.rlbl{position:absolute;font-size:13px;font-weight:bold;font-family:monospace;line-height:1;}
.rlbl-red{color:#d8281c;}
.rlbl-blue{color:#2a5ac4;}
.svg-area{flex:1;overflow:hidden;display:flex;min-height:0;background:#efeadd;}
.foot{padding:7px 12px;display:flex;align-items:center;justify-content:space-between;background:#f0ece1;border-top:1px solid #d8d2c2;flex-wrap:wrap;gap:4px;flex-shrink:0;}
.fstatus{font-size:11px;color:#1a6b3a;letter-spacing:1px;}
.zbtns{display:flex;gap:5px;}
.zb{background:#fdfaf3;border:1px solid #cfc7b6;color:#6b5b45;padding:4px 12px;border-radius:6px;cursor:pointer;font-size:11px;font-family:monospace;transition:background 0.15s;}
.zb:hover{background:#f3eee2;color:#3a2e20;}

/* ---------- DETAIL PANEL ---------- */
.panel-col{flex:0 0 40%;max-width:460px;background:#faf3e4;border:1.5px solid #e9dcc3;border-radius:16px;display:flex;flex-direction:column;height:100%;overflow:hidden;box-shadow:0 6px 18px rgba(120,85,30,0.08);}
.panel-hdr{padding:16px 18px 12px;border-bottom:1px solid #ecdfc6;background:#faf3e4;}
.panel-name{font-size:19px;font-weight:900;letter-spacing:0.5px;margin-top:0;color:#2b2014;font-family:'Courier New',monospace;line-height:1.1;}
.panel-sub{font-size:12px;color:#8a7a64;margin-top:4px;font-family:sans-serif;font-weight:400;letter-spacing:0;}
.cls-btn{background:none;border:1px solid #d9cbab;color:#a08e72;width:28px;height:28px;border-radius:8px;cursor:pointer;font-size:14px;font-family:monospace;flex-shrink:0;transition:all 0.15s;line-height:1;}
.cls-btn:hover{color:#3a2e20;border-color:#b49b73;background:#f3e9d4;}
.panel-body{flex:1;overflow-y:auto;padding:14px 18px 20px;display:flex;flex-direction:column;gap:14px;background:#faf3e4;}
.pdiv{height:1px;background:#ecdfc6;margin:0;}
.plbl{font-size:10px;letter-spacing:3px;font-weight:700;margin-bottom:10px;color:#6b5b45;font-family:'Courier New',monospace;}
.pdesc{font-size:13px;color:#3a2e20;line-height:1.8;font-family:'Courier New',monospace;}
.ptags{display:flex;flex-wrap:wrap;gap:8px;margin-top:2px;}
.ptag{font-size:11px;padding:6px 14px;border-radius:8px;border:1.5px solid #e5d7bb;background:#fdf8ee;color:#4a3c2a;white-space:nowrap;font-family:sans-serif;font-weight:500;display:inline-flex;align-items:center;}
.phls{display:flex;flex-direction:column;gap:9px;}
.phl{display:flex;align-items:flex-start;gap:10px;font-size:12.5px;color:#3a2e20;line-height:1.5;font-family:sans-serif;}
.phl-check{width:20px;height:20px;border-radius:50%;background:#ee7a23;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.phl-check svg{width:11px;height:11px;fill:none;stroke:#fff;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round;}
.pawds{display:flex;flex-direction:column;gap:7px;}
.pawd{display:flex;gap:8px;font-size:11.5px;color:#92600a;line-height:1.55;font-family:sans-serif;font-weight:500;align-items:flex-start;}
.plinks-row{display:flex;gap:8px;margin-top:2px;}
.plink-sm{flex:1;text-align:center;padding:10px 6px;border-radius:8px;font-size:11px;text-decoration:none;border:1.5px solid #e5d7bb;color:#4a3c2a;background:#fdf8ee;font-family:sans-serif;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:5px;transition:background 0.15s;}
.plink-sm:hover{background:#f3e9d4;}
.plink-main{width:100%;text-align:center;padding:15px 16px;border-radius:10px;font-size:13px;text-decoration:none;border:none;color:#2b1505;background:#ee7a23;font-family:'Courier New',monospace;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:space-between;letter-spacing:2px;transition:background 0.15s;margin-top:4px;}
.plink-main:hover{background:#e06a12;}
.plinks{display:flex;flex-direction:column;gap:10px;}
.pempty{flex:1;min-height:0;overflow-y:auto;display:flex;flex-direction:column;align-items:center;justify-content:safe center;padding:16px;gap:10px;}
.pempty-icon{font-size:48px;}
.pempty-txt{font-size:14px;color:#a08e72;text-align:center;line-height:1.8;font-family:'Courier New',monospace;letter-spacing:2px;}
.sc-list{width:100%;margin-top:8px;display:flex;flex-direction:column;gap:7px;}
.scb{width:100%;background:#fdf8ee;border:1.5px solid #e5d7bb;color:#4a3c2a;padding:11px 14px;border-radius:10px;cursor:pointer;font-size:12px;font-family:monospace;text-align:left;letter-spacing:1.5px;transition:background 0.15s;font-weight:600;}
.scb:hover{background:#f3e9d4;color:#2b2014;}

/* flowing "current" dashes along the energized power-indicator loop */
.bb-flow{stroke-dasharray:4 11;animation:bbflow 0.55s linear infinite;}
@keyframes bbflow{to{stroke-dashoffset:-15;}}

/* ---------- RESPONSIVE ---------- */
@media (max-width: 880px){
  .bb-outer{height:auto;min-height:0;}
  .wrap{height:auto;padding:14px 12px 16px;}
  .main{flex-direction:column;min-height:0;}
  .board-col{flex:none;width:100%;}
  .svg-area{aspect-ratio:1000/580;}
  .panel-col{flex:none;width:100%;max-width:none;height:auto;}
  .panel-body{overflow-y:visible;}
  .pempty{overflow-y:visible;}
  .ttl{font-size:17px;letter-spacing:3px;}
  .leg{font-size:13px;gap:14px;}
}
</style>

